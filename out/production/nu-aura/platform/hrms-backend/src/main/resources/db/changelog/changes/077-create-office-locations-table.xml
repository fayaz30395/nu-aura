<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="077-01" author="system">
        <comment>Create office_locations table for GPS geofencing</comment>
        <createTable tableName="office_locations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="location_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="location_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="address" type="TEXT"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="state" type="VARCHAR(100)"/>
            <column name="country" type="VARCHAR(100)"/>
            <column name="zip_code" type="VARCHAR(20)"/>
            <column name="latitude" type="DECIMAL(10,8)">
                <constraints nullable="false"/>
            </column>
            <column name="longitude" type="DECIMAL(11,8)">
                <constraints nullable="false"/>
            </column>
            <column name="geofence_radius_meters" type="INTEGER" defaultValue="100"/>
            <column name="is_geofence_enabled" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="allow_remote_checkin" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_headquarters" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="timezone" type="VARCHAR(50)" defaultValue="Asia/Kolkata"/>
            <column name="working_days" type="VARCHAR(50)" defaultValue="MON,TUE,WED,THU,FRI"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="office_locations" indexName="idx_office_location_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="office_locations" indexName="idx_office_location_active">
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <changeSet id="077-02" author="system">
        <comment>Add geofencing columns to attendance_records</comment>
        <addColumn tableName="attendance_records">
            <column name="check_in_latitude" type="DECIMAL(10,8)"/>
            <column name="check_in_longitude" type="DECIMAL(11,8)"/>
            <column name="check_out_latitude" type="DECIMAL(10,8)"/>
            <column name="check_out_longitude" type="DECIMAL(11,8)"/>
            <column name="check_in_office_location_id" type="UUID"/>
            <column name="check_out_office_location_id" type="UUID"/>
            <column name="check_in_within_geofence" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="check_out_within_geofence" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="check_in_distance_meters" type="INTEGER"/>
            <column name="check_out_distance_meters" type="INTEGER"/>
            <column name="is_remote_checkin" type="BOOLEAN" defaultValueBoolean="false"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
