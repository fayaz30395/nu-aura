<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-create-file-metadata-table" author="system">
        <createTable tableName="file_metadata">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="file_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="storage_path" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="content_type" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="varchar(100)"/>
            <column name="entity_id" type="uuid"/>
            <column name="category" type="varchar(50)"/>
            <column name="description" type="text"/>
            <column name="checksum" type="varchar(64)"/>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="uuid"/>
            <column name="last_modified_by" type="uuid"/>
            <column name="version" type="bigint"/>
        </createTable>

        <createIndex indexName="idx_file_tenant" tableName="file_metadata">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_file_entity" tableName="file_metadata">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </createIndex>

        <createIndex indexName="idx_file_category" tableName="file_metadata">
            <column name="category"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="file_metadata" baseColumnNames="tenant_id"
                                 constraintName="fk_file_tenant"
                                 referencedTableName="tenants" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
