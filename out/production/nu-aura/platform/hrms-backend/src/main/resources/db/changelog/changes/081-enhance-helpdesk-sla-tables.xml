<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="081-01" author="system">
        <comment>Create ticket_slas table</comment>
        <createTable tableName="ticket_slas">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="category_id" type="UUID"/>
            <column name="priority" type="VARCHAR(20)"/>
            <column name="first_response_minutes" type="INTEGER" defaultValue="60">
                <constraints nullable="false"/>
            </column>
            <column name="resolution_minutes" type="INTEGER" defaultValue="480">
                <constraints nullable="false"/>
            </column>
            <column name="escalation_after_minutes" type="INTEGER" defaultValue="240"/>
            <column name="escalation_to" type="UUID"/>
            <column name="second_escalation_minutes" type="INTEGER"/>
            <column name="second_escalation_to" type="UUID"/>
            <column name="is_business_hours_only" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="business_start_hour" type="INTEGER" defaultValue="9"/>
            <column name="business_end_hour" type="INTEGER" defaultValue="18"/>
            <column name="working_days" type="VARCHAR(50)" defaultValue="MON,TUE,WED,THU,FRI"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="apply_to_all_categories" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="081-02" author="system">
        <comment>Create ticket_escalations table</comment>
        <createTable tableName="ticket_escalations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="ticket_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="escalation_level" type="VARCHAR(20)" defaultValue="FIRST"/>
            <column name="escalation_reason" type="VARCHAR(30)"/>
            <column name="escalated_from" type="UUID"/>
            <column name="escalated_to" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="escalated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="is_auto_escalated" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="notes" type="TEXT"/>
            <column name="acknowledged_at" type="TIMESTAMP"/>
            <column name="acknowledged_by" type="UUID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="081-03" author="system">
        <comment>Create ticket_metrics table</comment>
        <createTable tableName="ticket_metrics">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="ticket_id" type="UUID">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="sla_id" type="UUID"/>
            <column name="first_response_at" type="TIMESTAMP"/>
            <column name="first_response_minutes" type="INTEGER"/>
            <column name="first_response_sla_breached" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="resolution_at" type="TIMESTAMP"/>
            <column name="resolution_minutes" type="INTEGER"/>
            <column name="resolution_sla_breached" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="total_handle_time_minutes" type="INTEGER" defaultValue="0"/>
            <column name="total_wait_time_minutes" type="INTEGER" defaultValue="0"/>
            <column name="reopen_count" type="INTEGER" defaultValue="0"/>
            <column name="reassignment_count" type="INTEGER" defaultValue="0"/>
            <column name="escalation_count" type="INTEGER" defaultValue="0"/>
            <column name="comment_count" type="INTEGER" defaultValue="0"/>
            <column name="csat_rating" type="INTEGER"/>
            <column name="csat_feedback" type="TEXT"/>
            <column name="csat_submitted_at" type="TIMESTAMP"/>
            <column name="first_contact_resolution" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="sla_met" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="081-04" author="system">
        <comment>Enhance ticket_categories table</comment>
        <addColumn tableName="ticket_categories">
            <column name="code" type="VARCHAR(50)"/>
            <column name="parent_category_id" type="UUID"/>
            <column name="department_type" type="VARCHAR(30)"/>
            <column name="default_assignee_role" type="VARCHAR(100)"/>
            <column name="sla_id" type="UUID"/>
            <column name="icon" type="VARCHAR(50)"/>
            <column name="color" type="VARCHAR(20)"/>
            <column name="requires_approval" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="approval_workflow_id" type="UUID"/>
            <column name="auto_close_after_days" type="INTEGER"/>
            <column name="is_visible_to_employees" type="BOOLEAN" defaultValueBoolean="true"/>
        </addColumn>
    </changeSet>

    <changeSet id="081-05" author="system">
        <comment>Add SLA tracking columns to tickets table</comment>
        <addColumn tableName="tickets">
            <column name="sla_id" type="UUID"/>
            <column name="first_response_due" type="TIMESTAMP"/>
            <column name="first_response_at" type="TIMESTAMP"/>
            <column name="first_response_breached" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="resolution_due" type="TIMESTAMP"/>
            <column name="resolution_breached" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="current_escalation_level" type="INTEGER" defaultValue="0"/>
            <column name="is_escalated" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="source" type="VARCHAR(30)"/>
            <column name="satisfaction_rating" type="INTEGER"/>
            <column name="satisfaction_feedback" type="TEXT"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
