<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Custom Field Definitions Table -->
    <changeSet id="076-create-custom-field-definitions-table" author="hrms">
        <createTable tableName="custom_field_definitions">
            <column name="id" type="uuid"><constraints primaryKey="true"/></column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="field_code" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="field_name" type="varchar(200)"><constraints nullable="false"/></column>
            <column name="description" type="varchar(500)"/>
            <column name="entity_type" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="field_type" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="field_group" type="varchar(100)"/>
            <column name="display_order" type="int" defaultValue="0"><constraints nullable="false"/></column>
            <column name="is_required" type="boolean" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="is_active" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="is_searchable" type="boolean" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="show_in_list" type="boolean" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="default_value" type="varchar(1000)"/>
            <column name="placeholder" type="varchar(200)"/>
            <column name="options" type="text"/>
            <column name="validation_rules" type="text"/>
            <column name="min_value" type="double"/>
            <column name="max_value" type="double"/>
            <column name="min_length" type="int"/>
            <column name="max_length" type="int"/>
            <column name="allowed_file_types" type="varchar(200)"/>
            <column name="max_file_size" type="bigint"/>
            <column name="view_visibility" type="varchar(50)" defaultValue="ALL"/>
            <column name="edit_visibility" type="varchar(50)" defaultValue="ADMIN_HR"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="created_by" type="uuid"/>
            <column name="updated_by" type="uuid"/>
            <column name="version" type="bigint" defaultValue="0"/>
        </createTable>

        <addUniqueConstraint tableName="custom_field_definitions"
                             columnNames="field_code, tenant_id"
                             constraintName="uk_cfd_code_tenant"/>

        <createIndex tableName="custom_field_definitions" indexName="idx_cfd_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="custom_field_definitions" indexName="idx_cfd_entity_type">
            <column name="entity_type"/>
        </createIndex>
        <createIndex tableName="custom_field_definitions" indexName="idx_cfd_group">
            <column name="field_group"/>
        </createIndex>
        <createIndex tableName="custom_field_definitions" indexName="idx_cfd_active">
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <!-- Custom Field Values Table -->
    <changeSet id="076-create-custom-field-values-table" author="hrms">
        <createTable tableName="custom_field_values">
            <column name="id" type="uuid"><constraints primaryKey="true"/></column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="field_definition_id" type="uuid"><constraints nullable="false"/></column>
            <column name="entity_type" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="entity_id" type="uuid"><constraints nullable="false"/></column>
            <column name="text_value" type="text"/>
            <column name="number_value" type="decimal(19,4)"/>
            <column name="date_value" type="date"/>
            <column name="date_time_value" type="timestamp"/>
            <column name="boolean_value" type="boolean"/>
            <column name="multi_select_value" type="text"/>
            <column name="file_value" type="varchar(500)"/>
            <column name="file_name" type="varchar(255)"/>
            <column name="file_size" type="bigint"/>
            <column name="file_mime_type" type="varchar(100)"/>
            <column name="currency_code" type="varchar(3)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="created_by" type="uuid"/>
            <column name="updated_by" type="uuid"/>
            <column name="version" type="bigint" defaultValue="0"/>
        </createTable>

        <addUniqueConstraint tableName="custom_field_values"
                             columnNames="field_definition_id, entity_id"
                             constraintName="uk_cfv_definition_entity"/>

        <addForeignKeyConstraint baseTableName="custom_field_values"
                                 baseColumnNames="field_definition_id"
                                 constraintName="fk_cfv_definition"
                                 referencedTableName="custom_field_definitions"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <createIndex tableName="custom_field_values" indexName="idx_cfv_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="custom_field_values" indexName="idx_cfv_definition">
            <column name="field_definition_id"/>
        </createIndex>
        <createIndex tableName="custom_field_values" indexName="idx_cfv_entity">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </createIndex>
    </changeSet>

    <!-- Add custom field permissions -->
    <changeSet id="076-add-custom-field-permissions" author="hrms">
        <insert tableName="permissions">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="code" value="CUSTOM_FIELD:VIEW"/>
            <column name="name" value="View Custom Fields"/>
            <column name="description" value="View custom field definitions and values"/>
            <column name="resource" value="CUSTOM_FIELD"/>
            <column name="action" value="VIEW"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="permissions">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="code" value="CUSTOM_FIELD:CREATE"/>
            <column name="name" value="Create Custom Fields"/>
            <column name="description" value="Create custom field definitions"/>
            <column name="resource" value="CUSTOM_FIELD"/>
            <column name="action" value="CREATE"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="permissions">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="code" value="CUSTOM_FIELD:UPDATE"/>
            <column name="name" value="Update Custom Fields"/>
            <column name="description" value="Update custom field definitions and values"/>
            <column name="resource" value="CUSTOM_FIELD"/>
            <column name="action" value="UPDATE"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="permissions">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="code" value="CUSTOM_FIELD:DELETE"/>
            <column name="name" value="Delete Custom Fields"/>
            <column name="description" value="Delete custom field definitions and values"/>
            <column name="resource" value="CUSTOM_FIELD"/>
            <column name="action" value="DELETE"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
        <insert tableName="permissions">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="code" value="CUSTOM_FIELD:MANAGE"/>
            <column name="name" value="Manage Custom Fields"/>
            <column name="description" value="Full management of custom fields"/>
            <column name="resource" value="CUSTOM_FIELD"/>
            <column name="action" value="MANAGE"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
    </changeSet>

</databaseChangeLog>
