<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="069-01-create-social-posts-table" author="system">
        <createTable tableName="social_posts">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="author_id" type="UUID"><constraints nullable="false"/></column>
            <column name="post_type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="content" type="TEXT"/>
            <column name="media_urls" type="TEXT"/>
            <column name="visibility" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="is_pinned" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="pinned_at" type="TIMESTAMP"/>
            <column name="pinned_by" type="UUID"/>
            <column name="is_announcement" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="target_audience" type="VARCHAR(50)"/>
            <column name="department_id" type="UUID"/>
            <column name="location" type="VARCHAR(255)"/>
            <column name="celebration_type" type="VARCHAR(50)"/>
            <column name="celebrated_employee_id" type="UUID"/>
            <column name="achievement_title" type="VARCHAR(500)"/>
            <column name="likes_count" type="INT" defaultValueNumeric="0"/>
            <column name="comments_count" type="INT" defaultValueNumeric="0"/>
            <column name="shares_count" type="INT" defaultValueNumeric="0"/>
            <column name="is_edited" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="edited_at" type="TIMESTAMP"/>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="UUID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <createIndex indexName="idx_social_post_tenant" tableName="social_posts"><column name="tenant_id"/></createIndex>
        <createIndex indexName="idx_social_post_author" tableName="social_posts"><column name="tenant_id"/><column name="author_id"/></createIndex>
        <createIndex indexName="idx_social_post_type" tableName="social_posts"><column name="tenant_id"/><column name="post_type"/></createIndex>
        <createIndex indexName="idx_social_post_created" tableName="social_posts"><column name="tenant_id"/><column name="created_at"/></createIndex>
    </changeSet>

    <changeSet id="069-02-create-post-comments-table" author="system">
        <createTable tableName="post_comments">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="post_id" type="UUID"><constraints nullable="false"/></column>
            <column name="author_id" type="UUID"><constraints nullable="false"/></column>
            <column name="parent_comment_id" type="UUID"/>
            <column name="content" type="TEXT"><constraints nullable="false"/></column>
            <column name="likes_count" type="INT" defaultValueNumeric="0"/>
            <column name="is_edited" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="edited_at" type="TIMESTAMP"/>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <createIndex indexName="idx_comment_tenant" tableName="post_comments"><column name="tenant_id"/></createIndex>
        <createIndex indexName="idx_comment_post" tableName="post_comments"><column name="tenant_id"/><column name="post_id"/></createIndex>
        <createIndex indexName="idx_comment_author" tableName="post_comments"><column name="tenant_id"/><column name="author_id"/></createIndex>
        <createIndex indexName="idx_comment_parent" tableName="post_comments"><column name="parent_comment_id"/></createIndex>
    </changeSet>

    <changeSet id="069-03-create-post-reactions-table" author="system">
        <createTable tableName="post_reactions">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="post_id" type="UUID"/>
            <column name="comment_id" type="UUID"/>
            <column name="employee_id" type="UUID"><constraints nullable="false"/></column>
            <column name="reaction_type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <createIndex indexName="idx_reaction_tenant" tableName="post_reactions"><column name="tenant_id"/></createIndex>
        <createIndex indexName="idx_reaction_post" tableName="post_reactions"><column name="tenant_id"/><column name="post_id"/></createIndex>
        <createIndex indexName="idx_reaction_employee" tableName="post_reactions"><column name="tenant_id"/><column name="employee_id"/></createIndex>
    </changeSet>

    <changeSet id="069-04-create-post-mentions-table" author="system">
        <createTable tableName="post_mentions">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="post_id" type="UUID"/>
            <column name="comment_id" type="UUID"/>
            <column name="mentioned_employee_id" type="UUID"><constraints nullable="false"/></column>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="read_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <createIndex indexName="idx_mention_tenant" tableName="post_mentions"><column name="tenant_id"/></createIndex>
        <createIndex indexName="idx_mention_post" tableName="post_mentions"><column name="tenant_id"/><column name="post_id"/></createIndex>
        <createIndex indexName="idx_mention_employee" tableName="post_mentions"><column name="tenant_id"/><column name="mentioned_employee_id"/></createIndex>
    </changeSet>

</databaseChangeLog>
