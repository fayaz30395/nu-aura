<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="053-update-shifts-table" author="hrms">
        <addColumn tableName="shifts">
            <column name="shift_type" type="varchar(20)" defaultValue="FIXED">
                <constraints nullable="true"/>
            </column>
            <column name="color_code" type="varchar(7)" defaultValue="#3B82F6">
                <constraints nullable="true"/>
            </column>
            <column name="allows_overtime" type="boolean" defaultValueBoolean="true">
                <constraints nullable="true"/>
            </column>
            <column name="overtime_multiplier" type="decimal(3,2)" defaultValue="1.50">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <createIndex tableName="shifts" indexName="idx_shifts_type">
            <column name="shift_type"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
