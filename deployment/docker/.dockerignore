# Docker ignore file for HRMS Platform
# Prevents unnecessary files from being included in Docker images

# Version Control
.git/
.gitignore
.gitattributes
.github/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.iml

# Build artifacts
target/
build/
dist/
out/
.next/
node_modules/
*.class
*.jar
*.war
*.ear

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output/
*.test.js
*.spec.js
__tests__/
test/
tests/
*.test.ts
*.spec.ts

# Environment files
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# Documentation
*.md
docs/
documentation/
README*
CHANGELOG*
LICENSE

# CI/CD
.gitlab-ci.yml
.travis.yml
Jenkinsfile
azure-pipelines.yml
cloudbuild.yaml

# Deployment
deployment/
kubernetes/
docker-compose.yml
docker-compose.*.yml
Dockerfile*
.dockerignore

# Dependencies (if using volume mounts)
!node_modules/.cache/

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.cache

# OS files
Thumbs.db
Desktop.ini

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# Maven specific
.mvn/
mvnw
mvnw.cmd

# Gradle
.gradle/
gradle/
gradlew
gradlew.bat

# NPM/Yarn
.npm/
.yarn/
.pnp.*
.yarn-integrity

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db

# Linux
*~

# Backup files
*.bak
*.backup
*.old

# Database files
*.db
*.sqlite
*.sqlite3

# Certificates (should be in secrets)
*.pem
*.key
*.crt
*.p12
*.jks
