<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-create-members-table" author="system">
        <createTable tableName="project_members" schemaName="pm">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="user_name" type="VARCHAR(200)"/>
            <column name="email" type="VARCHAR(200)"/>
            <column name="role" type="VARCHAR(30)" defaultValue="MEMBER">
                <constraints nullable="false"/>
            </column>
            <column name="joined_date" type="DATE"/>
            <column name="left_date" type="DATE"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="hours_per_week" type="INTEGER"/>
            <column name="department" type="VARCHAR(100)"/>
            <column name="designation" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID"/>
            <column name="last_modified_by" type="UUID"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
        </createTable>

        <createIndex tableName="project_members" indexName="idx_pm_member_tenant" schemaName="pm">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="project_members" indexName="idx_pm_member_project" schemaName="pm">
            <column name="project_id"/>
        </createIndex>

        <createIndex tableName="project_members" indexName="idx_pm_member_user" schemaName="pm">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="project_members" indexName="idx_pm_member_project_user" unique="true" schemaName="pm">
            <column name="project_id"/>
            <column name="user_id"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="project_members" baseColumnNames="project_id"
                                 baseTableSchemaName="pm"
                                 constraintName="fk_pm_member_project"
                                 referencedTableName="projects" referencedColumnNames="id"
                                 referencedTableSchemaName="pm"
                                 onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
