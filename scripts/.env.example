# NU-AURA Environment Configuration
# Copy this file to .env and update the values

# ============================================================================
# POSTGRESQL
# ============================================================================
POSTGRES_PASSWORD=hrms_dev_password
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hrms_dev
DB_USERNAME=hrms
DB_PASSWORD=hrms_dev_password

# ============================================================================
# REDIS
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# KAFKA
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_PREFIX=hrms

# ============================================================================
# MINIO (Object Storage)
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=hrms-documents

# ============================================================================
# APPLICATION
# ============================================================================
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRATION=86400000

# ============================================================================
# SECURITY (CHANGE THESE IN PRODUCTION!)
# ============================================================================
# Generate strong passwords for production:
# openssl rand -base64 32

# PostgreSQL password (same as POSTGRES_PASSWORD above)
# DB_PASSWORD=<generate-strong-password>

# MinIO password (same as MINIO_ROOT_PASSWORD above)
# MINIO_ROOT_PASSWORD=<generate-strong-password>

# JWT secret
# JWT_SECRET=<generate-strong-secret>
