<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="061-create-surveys-table" author="hrms">
        <createTable tableName="surveys">
            <column name="id" type="uuid"><constraints primaryKey="true"/></column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="survey_code" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="title" type="varchar(200)"><constraints nullable="false"/></column>
            <column name="description" type="text"/>
            <column name="survey_type" type="varchar(50)"/>
            <column name="is_anonymous" type="boolean" defaultValueBoolean="false"/>
            <column name="start_date" type="timestamp"/>
            <column name="end_date" type="timestamp"/>
            <column name="status" type="varchar(20)" defaultValue="DRAFT"/>
            <column name="target_audience" type="varchar(50)"/>
            <column name="total_responses" type="integer" defaultValue="0"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_by" type="uuid"/>
            <column name="version" type="bigint" defaultValue="0"/>
        </createTable>
        <addUniqueConstraint tableName="surveys" columnNames="tenant_id, survey_code"/>
        <createIndex tableName="surveys" indexName="idx_survey_tenant"><column name="tenant_id"/></createIndex>
    </changeSet>
</databaseChangeLog>
