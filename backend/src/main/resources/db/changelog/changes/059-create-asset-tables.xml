<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="059-create-assets-table" author="hrms">
        <createTable tableName="assets">
            <column name="id" type="uuid"><constraints primaryKey="true"/></column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="asset_code" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="asset_name" type="varchar(200)"><constraints nullable="false"/></column>
            <column name="category" type="varchar(50)"/>
            <column name="brand" type="varchar(100)"/>
            <column name="model" type="varchar(100)"/>
            <column name="serial_number" type="varchar(100)"/>
            <column name="purchase_date" type="date"/>
            <column name="purchase_cost" type="decimal(10,2)"/>
            <column name="current_value" type="decimal(10,2)"/>
            <column name="status" type="varchar(20)" defaultValue="AVAILABLE"/>
            <column name="assigned_to" type="uuid"/>
            <column name="location" type="varchar(200)"/>
            <column name="warranty_expiry" type="date"/>
            <column name="notes" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="version" type="bigint" defaultValue="0"/>
        </createTable>
        <addUniqueConstraint tableName="assets" columnNames="tenant_id, asset_code"/>
        <addForeignKeyConstraint baseTableName="assets" baseColumnNames="assigned_to"
                                 constraintName="fk_asset_employee" referencedTableName="employees"
                                 referencedColumnNames="id" onDelete="SET NULL"/>
        <createIndex tableName="assets" indexName="idx_asset_tenant"><column name="tenant_id"/></createIndex>
        <createIndex tableName="assets" indexName="idx_asset_status"><column name="status"/></createIndex>
    </changeSet>
</databaseChangeLog>
