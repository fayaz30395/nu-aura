<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="117-01-create-poll-options-table" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="poll_options"/>
            </not>
        </preConditions>
        <createTable tableName="poll_options">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="post_id" type="UUID"><constraints nullable="false"/></column>
            <column name="option_text" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="display_order" type="INT" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <createIndex indexName="idx_poll_option_tenant" tableName="poll_options"><column name="tenant_id"/></createIndex>
        <createIndex indexName="idx_poll_option_post" tableName="poll_options"><column name="tenant_id"/><column name="post_id"/></createIndex>
        <addForeignKeyConstraint baseTableName="poll_options" baseColumnNames="post_id"
                                 constraintName="fk_poll_option_post"
                                 referencedTableName="social_posts" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="117-02-create-poll-votes-table" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="poll_votes"/>
            </not>
        </preConditions>
        <createTable tableName="poll_votes">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="poll_option_id" type="UUID"><constraints nullable="false"/></column>
            <column name="employee_id" type="UUID"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <createIndex indexName="idx_poll_vote_tenant" tableName="poll_votes"><column name="tenant_id"/></createIndex>
        <createIndex indexName="idx_poll_vote_option" tableName="poll_votes"><column name="tenant_id"/><column name="poll_option_id"/></createIndex>
        <createIndex indexName="idx_poll_vote_employee" tableName="poll_votes"><column name="tenant_id"/><column name="employee_id"/></createIndex>
        <addForeignKeyConstraint baseTableName="poll_votes" baseColumnNames="poll_option_id"
                                 constraintName="fk_poll_vote_option"
                                 referencedTableName="poll_options" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="poll_votes" baseColumnNames="employee_id"
                                 constraintName="fk_poll_vote_employee"
                                 referencedTableName="employees" referencedColumnNames="id"/>
        <addUniqueConstraint tableName="poll_votes" columnNames="tenant_id, poll_option_id, employee_id"
                             constraintName="uk_poll_vote_unique"/>
    </changeSet>

</databaseChangeLog>
