<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="055-create-shift-swap-requests-table" author="hrms">
        <createTable tableName="shift_swap_requests">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="requester_employee_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="requester_assignment_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="requester_shift_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="target_employee_id" type="uuid"/>
            <column name="target_assignment_id" type="uuid"/>
            <column name="target_shift_date" type="date"/>
            <column name="swap_type" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="text"/>
            <column name="requested_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="target_employee_response" type="timestamp"/>
            <column name="target_employee_action" type="varchar(20)"/>
            <column name="approver_id" type="uuid"/>
            <column name="approved_at" type="timestamp"/>
            <column name="rejected_at" type="timestamp"/>
            <column name="rejection_reason" type="text"/>
            <column name="completed_at" type="timestamp"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="bigint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes -->
        <createIndex tableName="shift_swap_requests" indexName="idx_swap_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="shift_swap_requests" indexName="idx_swap_requester">
            <column name="requester_employee_id"/>
        </createIndex>
        <createIndex tableName="shift_swap_requests" indexName="idx_swap_target">
            <column name="target_employee_id"/>
        </createIndex>
        <createIndex tableName="shift_swap_requests" indexName="idx_swap_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="shift_swap_requests" indexName="idx_swap_date">
            <column name="requester_shift_date"/>
        </createIndex>

        <!-- Foreign Keys -->
        <addForeignKeyConstraint
                baseTableName="shift_swap_requests"
                baseColumnNames="requester_employee_id"
                constraintName="fk_swap_requester_employee"
                referencedTableName="employees"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="shift_swap_requests"
                baseColumnNames="target_employee_id"
                constraintName="fk_swap_target_employee"
                referencedTableName="employees"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="shift_swap_requests"
                baseColumnNames="requester_assignment_id"
                constraintName="fk_swap_requester_assignment"
                referencedTableName="shift_assignments"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
