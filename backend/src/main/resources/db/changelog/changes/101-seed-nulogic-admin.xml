        </preConditions>

        <comment>Assign SUPER_ADMIN, TENANT_ADMIN, and EMPLOYEE roles to NuLogic admin</comment>

        <sql>
            INSERT INTO user_roles (user_id, role_id)
            VALUES
                ('770e8400-e29b-41d4-a716-446655440001', '22222222-2222-2222-2222-222222222001'),
                ('770e8400-e29b-41d4-a716-446655440001', '22222222-2222-2222-2222-222222222002'),
                ('770e8400-e29b-41d4-a716-446655440001', '22222222-2222-2222-2222-222222222007')
