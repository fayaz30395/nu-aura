    <!-- ========================================= -->

    <!-- Create NuLogic Tenant -->
    <changeSet id="101-seed-nulogic-tenant" author="system">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM tenants WHERE code = 'nulogic'
            </sqlCheck>
        </preConditions>

        <insert tableName="tenants">
            <column name="id" value="660e8400-e29b-41d4-a716-446655440001"/>
            <column name="code" value="nulogic"/>
            <column name="name" value="NuLogic Technologies"/>
            <column name="status" value="ACTIVE"/>
            <column name="contact_email" value="admin@nulogic.io"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
            <column name="version" value="0"/>
        </insert>
    </changeSet>

