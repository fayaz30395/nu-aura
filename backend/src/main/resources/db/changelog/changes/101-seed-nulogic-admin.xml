            <column name="email" value="fayaz.m@nulogic.io"/>
            <column name="first_name" value="Fayaz"/>
            <column name="last_name" value="Admin"/>
            <column name="password_hash" value="$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZRGdjGj/n3NkCmSlMqJPJXAJFkXfC"/>
            <column name="status" value="ACTIVE"/>
            <column name="created_at" valueDate="now()"/>
