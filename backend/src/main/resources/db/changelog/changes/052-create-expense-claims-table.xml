<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="052-create-expense-claims-table" author="hrms">
        <createTable tableName="expense_claims">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="claim_number" type="varchar(50)">
                <constraints unique="true"/>
            </column>
            <column name="claim_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="varchar(3)" defaultValue="USD">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="receipt_url" type="varchar(500)"/>
            <column name="submitted_at" type="timestamp"/>
            <column name="approved_by" type="uuid"/>
            <column name="approved_at" type="timestamp"/>
            <column name="rejected_by" type="uuid"/>
            <column name="rejected_at" type="timestamp"/>
            <column name="rejection_reason" type="varchar(500)"/>
            <column name="payment_date" type="date"/>
            <column name="payment_reference" type="varchar(100)"/>
            <column name="notes" type="varchar(1000)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes -->
        <createIndex tableName="expense_claims" indexName="idx_expense_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="expense_claims" indexName="idx_expense_employee">
            <column name="employee_id"/>
        </createIndex>
        <createIndex tableName="expense_claims" indexName="idx_expense_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="expense_claims" indexName="idx_expense_claim_date">
            <column name="claim_date"/>
        </createIndex>
        <createIndex tableName="expense_claims" indexName="idx_expense_category">
            <column name="category"/>
        </createIndex>

        <!-- Foreign Keys -->
        <addForeignKeyConstraint
                baseTableName="expense_claims"
                baseColumnNames="employee_id"
                constraintName="fk_expense_employee"
                referencedTableName="employees"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
