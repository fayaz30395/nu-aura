<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="068-01-create-tax-declarations-table" author="system">
        <createTable tableName="tax_declarations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="financial_year" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="tax_regime" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <!-- Section 80C -->
            <column name="sec_80c_ppf" type="DECIMAL(15,2)"/>
            <column name="sec_80c_epf" type="DECIMAL(15,2)"/>
            <column name="sec_80c_life_insurance" type="DECIMAL(15,2)"/>
            <column name="sec_80c_elss" type="DECIMAL(15,2)"/>
            <column name="sec_80c_nsc" type="DECIMAL(15,2)"/>
            <column name="sec_80c_home_loan_principal" type="DECIMAL(15,2)"/>
            <column name="sec_80c_tuition_fees" type="DECIMAL(15,2)"/>
            <column name="sec_80c_sukanya_samriddhi" type="DECIMAL(15,2)"/>
            <column name="sec_80c_nps_employee" type="DECIMAL(15,2)"/>
            <column name="sec_80c_total" type="DECIMAL(15,2)"/>

            <!-- Section 80CCD(1B) -->
            <column name="sec_80ccd_1b_nps_additional" type="DECIMAL(15,2)"/>

            <!-- Section 80D -->
            <column name="sec_80d_self_family" type="DECIMAL(15,2)"/>
            <column name="sec_80d_parents" type="DECIMAL(15,2)"/>
            <column name="sec_80d_preventive_health" type="DECIMAL(15,2)"/>
            <column name="sec_80d_total" type="DECIMAL(15,2)"/>

            <!-- Other Sections -->
            <column name="sec_80e_education_loan" type="DECIMAL(15,2)"/>
            <column name="sec_80g_donations" type="DECIMAL(15,2)"/>
            <column name="sec_80gg_rent_paid" type="DECIMAL(15,2)"/>
            <column name="sec_24_home_loan_interest" type="DECIMAL(15,2)"/>

            <!-- HRA -->
            <column name="hra_metro_city" type="BOOLEAN"/>
            <column name="hra_rent_paid" type="DECIMAL(15,2)"/>
            <column name="hra_exemption" type="DECIMAL(15,2)"/>

            <!-- Other Income -->
            <column name="other_income_interest" type="DECIMAL(15,2)"/>
            <column name="other_income_rental" type="DECIMAL(15,2)"/>
            <column name="other_income_capital_gains" type="DECIMAL(15,2)"/>
            <column name="other_income_total" type="DECIMAL(15,2)"/>

            <!-- Previous Employment -->
            <column name="previous_employer_name" type="VARCHAR(255)"/>
            <column name="previous_employer_pan" type="VARCHAR(10)"/>
            <column name="previous_employer_income" type="DECIMAL(15,2)"/>
            <column name="previous_employer_tax" type="DECIMAL(15,2)"/>

            <!-- Calculated Fields -->
            <column name="total_deductions" type="DECIMAL(15,2)"/>
            <column name="taxable_income" type="DECIMAL(15,2)"/>
            <column name="estimated_tax" type="DECIMAL(15,2)"/>

            <!-- Approval Workflow -->
            <column name="submitted_at" type="TIMESTAMP"/>
            <column name="approved_by" type="UUID"/>
            <column name="approved_at" type="TIMESTAMP"/>
            <column name="rejected_by" type="UUID"/>
            <column name="rejected_at" type="TIMESTAMP"/>
            <column name="rejection_reason" type="TEXT"/>
            <column name="locked_at" type="TIMESTAMP"/>
            <column name="notes" type="TEXT"/>

            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_tax_decl_tenant" tableName="tax_declarations">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_tax_decl_employee" tableName="tax_declarations">
            <column name="tenant_id"/>
            <column name="employee_id"/>
        </createIndex>
        <createIndex indexName="idx_tax_decl_year" tableName="tax_declarations">
            <column name="tenant_id"/>
            <column name="financial_year"/>
        </createIndex>
        <createIndex indexName="idx_tax_decl_status" tableName="tax_declarations">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="068-02-create-tax-proofs-table" author="system">
        <createTable tableName="tax_proofs">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="tax_declaration_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="proof_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="investment_section" type="VARCHAR(50)"/>
            <column name="proof_description" type="VARCHAR(500)"/>
            <column name="declared_amount" type="DECIMAL(15,2)"/>
            <column name="approved_amount" type="DECIMAL(15,2)"/>
            <column name="document_name" type="VARCHAR(500)"/>
            <column name="document_url" type="VARCHAR(1000)"/>
            <column name="document_type" type="VARCHAR(50)"/>
            <column name="document_size" type="BIGINT"/>
            <column name="issuer_name" type="VARCHAR(255)"/>
            <column name="policy_number" type="VARCHAR(100)"/>
            <column name="certificate_number" type="VARCHAR(100)"/>
            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="submitted_at" type="TIMESTAMP"/>
            <column name="verified_by" type="UUID"/>
            <column name="verified_at" type="TIMESTAMP"/>
            <column name="verification_notes" type="TEXT"/>
            <column name="rejected_by" type="UUID"/>
            <column name="rejected_at" type="TIMESTAMP"/>
            <column name="rejection_reason" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_tax_proof_tenant" tableName="tax_proofs">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_tax_proof_declaration" tableName="tax_proofs">
            <column name="tenant_id"/>
            <column name="tax_declaration_id"/>
        </createIndex>
        <createIndex indexName="idx_tax_proof_employee" tableName="tax_proofs">
            <column name="tenant_id"/>
            <column name="employee_id"/>
        </createIndex>
        <createIndex indexName="idx_tax_proof_status" tableName="tax_proofs">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="068-03-create-tax-regime-comparisons-table" author="system">
        <createTable tableName="tax_regime_comparisons">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="financial_year" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="gross_salary" type="DECIMAL(15,2)"/>
            <column name="standard_deduction" type="DECIMAL(15,2)"/>

            <!-- Old Regime -->
            <column name="old_regime_total_deductions" type="DECIMAL(15,2)"/>
            <column name="old_regime_taxable_income" type="DECIMAL(15,2)"/>
            <column name="old_regime_tax" type="DECIMAL(15,2)"/>
            <column name="old_regime_cess" type="DECIMAL(15,2)"/>
            <column name="old_regime_total_tax" type="DECIMAL(15,2)"/>

            <!-- New Regime -->
            <column name="new_regime_taxable_income" type="DECIMAL(15,2)"/>
            <column name="new_regime_tax" type="DECIMAL(15,2)"/>
            <column name="new_regime_cess" type="DECIMAL(15,2)"/>
            <column name="new_regime_rebate" type="DECIMAL(15,2)"/>
            <column name="new_regime_total_tax" type="DECIMAL(15,2)"/>

            <!-- Comparison -->
            <column name="tax_savings" type="DECIMAL(15,2)"/>
            <column name="recommended_regime" type="VARCHAR(20)"/>
            <column name="selected_regime" type="VARCHAR(20)"/>
            <column name="calculation_details" type="TEXT"/>

            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_tax_regime_tenant" tableName="tax_regime_comparisons">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_tax_regime_employee" tableName="tax_regime_comparisons">
            <column name="tenant_id"/>
            <column name="employee_id"/>
        </createIndex>
        <createIndex indexName="idx_tax_regime_year" tableName="tax_regime_comparisons">
            <column name="tenant_id"/>
            <column name="financial_year"/>
        </createIndex>
    </changeSet>

    <changeSet id="068-04-add-foreign-keys" author="system">
        <addForeignKeyConstraint
                baseTableName="tax_proofs"
                baseColumnNames="tax_declaration_id"
                constraintName="fk_tax_proof_declaration"
                referencedTableName="tax_declarations"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
