<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="088-01-create-letter-templates-table" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="letter_templates"/>
            </not>
        </preConditions>
        <createTable tableName="letter_templates">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="template_content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="header_html" type="TEXT"/>
            <column name="footer_html" type="TEXT"/>
            <column name="css_styles" type="TEXT"/>
            <column name="include_company_logo" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="include_signature" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="signature_title" type="VARCHAR(100)"/>
            <column name="signatory_name" type="VARCHAR(200)"/>
            <column name="signatory_designation" type="VARCHAR(200)"/>
            <column name="requires_approval" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="is_system_template" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="template_version" type="INTEGER"/>
            <column name="available_placeholders" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
        </createTable>

        <createIndex tableName="letter_templates" indexName="idx_letter_templates_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="letter_templates" indexName="idx_letter_templates_category">
            <column name="category"/>
        </createIndex>
        <createIndex tableName="letter_templates" indexName="idx_letter_templates_active">
            <column name="is_active"/>
        </createIndex>

        <addForeignKeyConstraint
            baseTableName="letter_templates"
            baseColumnNames="tenant_id"
            referencedTableName="tenants"
            referencedColumnNames="id"
            constraintName="fk_letter_templates_tenant"/>
    </changeSet>

    <changeSet id="088-02-create-generated-letters-table" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="generated_letters"/>
            </not>
        </preConditions>
        <createTable tableName="generated_letters">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="reference_number" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="template_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="letter_title" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="generated_content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="pdf_url" type="TEXT"/>
            <column name="letter_date" type="DATE"/>
            <column name="effective_date" type="DATE"/>
            <column name="expiry_date" type="DATE"/>
            <column name="status" type="VARCHAR(30)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="generated_by" type="UUID"/>
            <column name="generated_at" type="TIMESTAMP"/>
            <column name="approved_by" type="UUID"/>
            <column name="approved_at" type="TIMESTAMP"/>
            <column name="approval_comments" type="TEXT"/>
            <column name="issued_by" type="UUID"/>
            <column name="issued_at" type="TIMESTAMP"/>
            <column name="sent_to_employee" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="sent_at" type="TIMESTAMP"/>
            <column name="downloaded_by_employee" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="downloaded_at" type="TIMESTAMP"/>
            <column name="additional_notes" type="TEXT"/>
            <column name="custom_placeholder_values" type="TEXT"/>
            <column name="letter_version" type="INTEGER" defaultValueNumeric="1"/>
            <column name="previous_version_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
        </createTable>

        <createIndex tableName="generated_letters" indexName="idx_generated_letters_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="generated_letters" indexName="idx_generated_letters_employee">
            <column name="employee_id"/>
        </createIndex>
        <createIndex tableName="generated_letters" indexName="idx_generated_letters_template">
            <column name="template_id"/>
        </createIndex>
        <createIndex tableName="generated_letters" indexName="idx_generated_letters_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="generated_letters" indexName="idx_generated_letters_category">
            <column name="category"/>
        </createIndex>

        <addForeignKeyConstraint
            baseTableName="generated_letters"
            baseColumnNames="tenant_id"
            referencedTableName="tenants"
            referencedColumnNames="id"
            constraintName="fk_generated_letters_tenant"/>
        <addForeignKeyConstraint
            baseTableName="generated_letters"
            baseColumnNames="template_id"
            referencedTableName="letter_templates"
            referencedColumnNames="id"
            constraintName="fk_generated_letters_template"/>
        <addForeignKeyConstraint
            baseTableName="generated_letters"
            baseColumnNames="employee_id"
            referencedTableName="employees"
            referencedColumnNames="id"
            constraintName="fk_generated_letters_employee"/>
    </changeSet>

</databaseChangeLog>
