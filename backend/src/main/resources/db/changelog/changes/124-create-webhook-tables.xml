<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Webhooks table for external integrations -->
    <changeSet id="124-1-create-webhooks-table" author="system">
        <createTable tableName="webhooks">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="url" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="secret" type="VARCHAR(256)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="consecutive_failures" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="last_success_at" type="TIMESTAMP"/>
            <column name="last_failure_at" type="TIMESTAMP"/>
            <column name="last_error_message" type="VARCHAR(1000)"/>
            <column name="include_payload" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="custom_headers" type="TEXT"/>
            <column name="max_retries" type="INT" defaultValueNumeric="3">
                <constraints nullable="false"/>
            </column>
            <column name="timeout_seconds" type="INT" defaultValueNumeric="30">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="webhooks" indexName="idx_webhook_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="webhooks" indexName="idx_webhook_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="webhooks" indexName="idx_webhook_tenant_status">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <!-- Webhook events junction table -->
    <changeSet id="124-2-create-webhook-events-table" author="system">
        <createTable tableName="webhook_events">
            <column name="webhook_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="webhook_events" columnNames="webhook_id,event_type"/>

        <addForeignKeyConstraint
                baseTableName="webhook_events"
                baseColumnNames="webhook_id"
                constraintName="fk_webhook_events_webhook"
                referencedTableName="webhooks"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

    <!-- Webhook deliveries table for tracking delivery attempts -->
    <changeSet id="124-3-create-webhook-deliveries-table" author="system">
        <createTable tableName="webhook_deliveries">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="webhook_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="TEXT"/>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="attempts" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="next_retry_at" type="TIMESTAMP"/>
            <column name="response_status" type="INT"/>
            <column name="response_body" type="VARCHAR(2000)"/>
            <column name="duration_ms" type="BIGINT"/>
            <column name="error_message" type="VARCHAR(1000)"/>
            <column name="first_attempt_at" type="TIMESTAMP"/>
            <column name="last_attempt_at" type="TIMESTAMP"/>
            <column name="delivered_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="webhook_deliveries" indexName="idx_delivery_webhook">
            <column name="webhook_id"/>
        </createIndex>
        <createIndex tableName="webhook_deliveries" indexName="idx_delivery_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="webhook_deliveries" indexName="idx_delivery_created">
            <column name="created_at"/>
        </createIndex>
        <createIndex tableName="webhook_deliveries" indexName="idx_delivery_event">
            <column name="event_type"/>
        </createIndex>
        <createIndex tableName="webhook_deliveries" indexName="idx_delivery_retry">
            <column name="status"/>
            <column name="next_retry_at"/>
        </createIndex>
        <createIndex tableName="webhook_deliveries" indexName="idx_delivery_idempotency">
            <column name="webhook_id"/>
            <column name="event_id"/>
        </createIndex>

        <addForeignKeyConstraint
                baseTableName="webhook_deliveries"
                baseColumnNames="webhook_id"
                constraintName="fk_delivery_webhook"
                referencedTableName="webhooks"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
