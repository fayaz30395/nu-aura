<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="021-create-leave-types-table" author="hrms">
        <createTable tableName="leave_types">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="leave_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="leave_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="is_paid" type="BOOLEAN" defaultValue="true"/>
            <column name="color_code" type="VARCHAR(20)"/>
            <column name="annual_quota" type="DECIMAL(5,2)"/>
            <column name="max_consecutive_days" type="INTEGER"/>
            <column name="min_days_notice" type="INTEGER" defaultValue="0"/>
            <column name="max_days_per_request" type="INTEGER"/>
            <column name="is_carry_forward_allowed" type="BOOLEAN" defaultValue="false"/>
            <column name="max_carry_forward_days" type="DECIMAL(5,2)"/>
            <column name="is_encashable" type="BOOLEAN" defaultValue="false"/>
            <column name="requires_document" type="BOOLEAN" defaultValue="false"/>
            <column name="applicable_after_days" type="INTEGER" defaultValue="0"/>
            <column name="accrual_type" type="VARCHAR(50)"/>
            <column name="accrual_rate" type="DECIMAL(5,2)"/>
            <column name="gender_specific" type="VARCHAR(20)"/>
            <column name="is_active" type="BOOLEAN" defaultValue="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
            <column name="version" type="BIGINT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="leave_types"
                             columnNames="tenant_id, leave_code"
                             constraintName="uk_leave_types_tenant_code"/>

        <createIndex tableName="leave_types" indexName="idx_leave_types_tenant_id">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="leave_types" indexName="idx_leave_types_active">
            <column name="is_active"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
