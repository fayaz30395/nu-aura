<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="116-create-employment-change-requests-table" author="antigravity">
        <createTable tableName="employment_change_requests">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="requester_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="approver_id" type="uuid"/>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="change_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <!-- Current values (before change) -->
            <column name="current_designation" type="VARCHAR(255)"/>
            <column name="current_level" type="VARCHAR(50)"/>
            <column name="current_job_role" type="VARCHAR(50)"/>
            <column name="current_department_id" type="uuid"/>
            <column name="current_manager_id" type="uuid"/>
            <column name="current_employment_type" type="VARCHAR(20)"/>
            <column name="current_confirmation_date" type="DATE"/>
            <column name="current_status" type="VARCHAR(20)"/>

            <!-- New values (requested changes) -->
            <column name="new_designation" type="VARCHAR(255)"/>
            <column name="new_level" type="VARCHAR(50)"/>
            <column name="new_job_role" type="VARCHAR(50)"/>
            <column name="new_department_id" type="uuid"/>
            <column name="new_manager_id" type="uuid"/>
            <column name="new_employment_type" type="VARCHAR(20)"/>
            <column name="new_confirmation_date" type="DATE"/>
            <column name="new_status" type="VARCHAR(20)"/>

            <!-- Metadata -->
            <column name="reason" type="VARCHAR(500)"/>
            <column name="rejection_reason" type="VARCHAR(500)"/>
            <column name="effective_date" type="DATE"/>
            <column name="approved_at" type="TIMESTAMP"/>
            <column name="rejected_at" type="TIMESTAMP"/>

            <!-- Audit columns -->
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="uuid"/>
            <column name="updated_by" type="uuid"/>
            <column name="version" type="BIGINT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="employment_change_requests"
                baseColumnNames="employee_id"
                constraintName="fk_emp_change_requests_employee"
                referencedTableName="employees"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                baseTableName="employment_change_requests"
                baseColumnNames="tenant_id"
                constraintName="fk_emp_change_requests_tenant"
                referencedTableName="tenants"
                referencedColumnNames="id"/>

        <createIndex tableName="employment_change_requests" indexName="idx_emp_change_requests_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="employment_change_requests" indexName="idx_emp_change_requests_employee">
            <column name="employee_id"/>
        </createIndex>
        <createIndex tableName="employment_change_requests" indexName="idx_emp_change_requests_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="employment_change_requests" indexName="idx_emp_change_requests_requester">
            <column name="requester_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
