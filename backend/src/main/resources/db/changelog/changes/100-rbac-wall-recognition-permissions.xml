    <!-- ========================================= -->

    <!-- Add Recognition Permissions to permissions table -->
    <changeSet id="100-add-recognition-permissions" author="system">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM permissions WHERE code = 'RECOGNITION:VIEW'</sqlCheck>
        </preConditions>

        <!-- Recognition Permissions -->
        <insert tableName="permissions">
            <column name="id" value="11111111-1111-1111-1111-111111113001"/>
            <column name="code" value="RECOGNITION:VIEW"/>
            <column name="name" value="View Recognition"/>
            <column name="description" value="View recognition posts and badges"/>
            <column name="resource" value="RECOGNITION"/>
            <column name="action" value="VIEW"/>
            <column name="created_at" valueDate="2024-01-01T00:00:00"/>
            <column name="updated_at" valueDate="2024-01-01T00:00:00"/>
        </insert>

        <insert tableName="permissions">
            <column name="id" value="11111111-1111-1111-1111-111111113002"/>
            <column name="code" value="RECOGNITION:CREATE"/>
            <column name="name" value="Give Recognition"/>
            <column name="description" value="Give recognition to colleagues"/>
            <column name="resource" value="RECOGNITION"/>
            <column name="action" value="CREATE"/>
            <column name="created_at" valueDate="2024-01-01T00:00:00"/>
            <column name="updated_at" valueDate="2024-01-01T00:00:00"/>
        </insert>

        <insert tableName="permissions">
            <column name="id" value="11111111-1111-1111-1111-111111113003"/>
            <column name="code" value="RECOGNITION:MANAGE"/>
            <column name="name" value="Manage Recognition"/>
            <column name="description" value="Manage recognition programs and badges"/>
            <column name="resource" value="RECOGNITION"/>
            <column name="action" value="MANAGE"/>
            <column name="created_at" valueDate="2024-01-01T00:00:00"/>
            <column name="updated_at" valueDate="2024-01-01T00:00:00"/>
        </insert>

        <insert tableName="permissions">
            <column name="id" value="11111111-1111-1111-1111-111111113004"/>
            <column name="code" value="MILESTONE:VIEW"/>
