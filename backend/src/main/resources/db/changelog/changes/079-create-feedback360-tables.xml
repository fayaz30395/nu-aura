<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="079-01" author="system">
        <comment>Create feedback_360_cycles table</comment>
        <createTable tableName="feedback_360_cycles">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="status" type="VARCHAR(30)" defaultValue="DRAFT"/>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="nomination_deadline" type="DATE"/>
            <column name="self_review_deadline" type="DATE"/>
            <column name="peer_review_deadline" type="DATE"/>
            <column name="manager_review_deadline" type="DATE"/>
            <column name="min_peers_required" type="INTEGER" defaultValue="3"/>
            <column name="max_peers_allowed" type="INTEGER" defaultValue="8"/>
            <column name="is_anonymous" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="include_self_review" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="include_manager_review" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="include_peer_review" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="include_upward_review" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="template_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="079-02" author="system">
        <comment>Create feedback_360_requests table</comment>
        <createTable tableName="feedback_360_requests">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="cycle_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="subject_employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="reviewer_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="reviewer_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)" defaultValue="PENDING"/>
            <column name="nominated_by" type="UUID"/>
            <column name="nomination_approved" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="approved_by" type="UUID"/>
            <column name="approved_at" type="TIMESTAMP"/>
            <column name="reminder_sent_at" type="TIMESTAMP"/>
            <column name="reminder_count" type="INTEGER" defaultValue="0"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="079-03" author="system">
        <comment>Create feedback_360_responses table</comment>
        <createTable tableName="feedback_360_responses">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="request_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="cycle_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="subject_employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="reviewer_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="reviewer_type" type="VARCHAR(30)"/>
            <column name="submitted_at" type="TIMESTAMP"/>
            <column name="is_draft" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="overall_rating" type="DECIMAL(3,2)"/>
            <column name="communication_rating" type="DECIMAL(3,2)"/>
            <column name="teamwork_rating" type="DECIMAL(3,2)"/>
            <column name="leadership_rating" type="DECIMAL(3,2)"/>
            <column name="problem_solving_rating" type="DECIMAL(3,2)"/>
            <column name="technical_skills_rating" type="DECIMAL(3,2)"/>
            <column name="adaptability_rating" type="DECIMAL(3,2)"/>
            <column name="work_quality_rating" type="DECIMAL(3,2)"/>
            <column name="time_management_rating" type="DECIMAL(3,2)"/>
            <column name="strengths" type="TEXT"/>
            <column name="areas_for_improvement" type="TEXT"/>
            <column name="additional_comments" type="TEXT"/>
            <column name="specific_examples" type="TEXT"/>
            <column name="development_suggestions" type="TEXT"/>
            <column name="custom_responses" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="079-04" author="system">
        <comment>Create feedback_360_summaries table</comment>
        <createTable tableName="feedback_360_summaries">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="cycle_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="subject_employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="total_reviewers" type="INTEGER" defaultValue="0"/>
            <column name="responses_received" type="INTEGER" defaultValue="0"/>
            <column name="self_review_completed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="manager_review_completed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="peer_reviews_completed" type="INTEGER" defaultValue="0"/>
            <column name="upward_reviews_completed" type="INTEGER" defaultValue="0"/>
            <column name="self_overall_rating" type="DECIMAL(3,2)"/>
            <column name="manager_overall_rating" type="DECIMAL(3,2)"/>
            <column name="peer_avg_rating" type="DECIMAL(3,2)"/>
            <column name="upward_avg_rating" type="DECIMAL(3,2)"/>
            <column name="final_rating" type="DECIMAL(3,2)"/>
            <column name="avg_communication" type="DECIMAL(3,2)"/>
            <column name="avg_teamwork" type="DECIMAL(3,2)"/>
            <column name="avg_leadership" type="DECIMAL(3,2)"/>
            <column name="avg_problem_solving" type="DECIMAL(3,2)"/>
            <column name="avg_technical_skills" type="DECIMAL(3,2)"/>
            <column name="avg_adaptability" type="DECIMAL(3,2)"/>
            <column name="avg_work_quality" type="DECIMAL(3,2)"/>
            <column name="avg_time_management" type="DECIMAL(3,2)"/>
            <column name="consolidated_strengths" type="TEXT"/>
            <column name="consolidated_improvements" type="TEXT"/>
            <column name="action_items" type="TEXT"/>
            <column name="generated_at" type="TIMESTAMP"/>
            <column name="shared_with_employee" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="shared_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
