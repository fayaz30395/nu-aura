<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Drop NOT NULL constraint on signer_id to support EXTERNAL signers (candidates) -->
    <changeSet id="121-01-allow-nullable-signer-id" author="system">
        <dropNotNullConstraint
            tableName="signature_approvals"
            columnName="signer_id"
            columnDataType="UUID"/>

        <comment>
            Allow null signer_id for EXTERNAL signers (e.g., candidates signing offer letters).
            External signers are identified by email and authentication token instead of employee ID.
        </comment>
    </changeSet>

    <!-- Add index for token lookup (used for external signing) -->
    <changeSet id="121-02-add-token-index" author="system">
        <createIndex indexName="idx_sig_appr_auth_token" tableName="signature_approvals">
            <column name="authentication_token"/>
        </createIndex>

        <comment>Index for quick token lookup during external signing</comment>
    </changeSet>

</databaseChangeLog>
