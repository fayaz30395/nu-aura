package com.hrms.api.performance;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.hrms.application.performance.dto.CompetencyRequest;
import com.hrms.application.performance.dto.CompetencyResponse;
import com.hrms.application.performance.dto.ReviewRequest;
import com.hrms.application.performance.dto.ReviewResponse;
import com.hrms.application.performance.service.PerformanceReviewService;
import com.hrms.common.security.*;
import org.junit.jupiter.api.*;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.data.domain.*;
import org.springframework.http.MediaType;
import org.springframework.security.core.userdetails.UserDetailsService;
import org.springframework.test.context.ActiveProfiles;
import org.springframework.test.context.ContextConfiguration;
import org.springframework.test.web.servlet.MockMvc;

import java.time.LocalDateTime;
import java.util.*;

import static org.hamcrest.Matchers.hasSize;
import static org.hamcrest.Matchers.is;
import static org.hamcrest.Matchers.notNullValue;
import static org.hamcrest.Matchers.nullValue;
import static org.hamcrest.Matchers.containsString;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

@WebMvcTest(PerformanceReviewController.class)
@ContextConfiguration(classes = {PerformanceReviewController.class, PerformanceReviewControllerTest.TestConfig.class})
@AutoConfigureMockMvc(addFilters = false)
@ExtendWith(MockitoExtension.class)
@ActiveProfiles("test")
@DisplayName("PerformanceReviewController Integration Tests")
class PerformanceReviewControllerTest {

    @Configuration
    static class TestConfig {
        @Bean
        public org.springframework.data.domain.AuditorAware<UUID> auditorProvider() {
            return () -> Optional.of(UUID.randomUUID());
        }
    }

    @Autowired
    private MockMvc mockMvc;

    @Autowired
    private ObjectMapper objectMapper;

    @MockBean
    private PerformanceReviewService reviewService;

    @MockBean
    private ApiKeyService apiKeyService;

    @MockBean
    private JwtTokenProvider jwtTokenProvider;

    @MockBean
    private UserDetailsService userDetailsService;

    @MockBean
    private ApiKeyAuthenticationFilter apiKeyAuthenticationFilter;

    @MockBean
    private JwtAuthenticationFilter jwtAuthenticationFilter;

    @MockBean
    private RateLimitFilter rateLimitFilter;

    @MockBean
    private RateLimitingFilter rateLimitingFilter;

    @MockBean
    private TenantFilter tenantFilter;

    private UUID reviewId;
    private UUID employeeId;
    private UUID reviewerId;
    private ReviewResponse reviewResponse;
    private CompetencyResponse competencyResponse;

    @BeforeEach
    void setUp() {
        reviewId = UUID.randomUUID();
        employeeId = UUID.randomUUID();
        reviewerId = UUID.randomUUID();

        reviewResponse = ReviewResponse.builder()
                .id(reviewId)
                .employeeId(employeeId)
                .reviewerId(reviewerId)
                .title("Annual Performance Review 2024")
                .status("DRAFT")
                .rating(4)
                .createdAt(LocalDateTime.now())
                .build();

        competencyResponse = CompetencyResponse.builder()
                .id(UUID.randomUUID())
                .reviewId(reviewId)
                .competencyName("Leadership")
                .rating(5)
                .feedback("Excellent leadership skills")
                .build();
    }

    @Nested
    @DisplayName("Review Creation Tests")
    class ReviewCreationTests {

        @Test
        @DisplayName("Should create review successfully")
        void shouldCreateReviewSuccessfully() throws Exception {
            ReviewRequest request = ReviewRequest.builder()
                    .employeeId(employeeId)
                    .reviewerId(reviewerId)
                    .title("Annual Performance Review 2024")
                    .reviewType("ANNUAL")
                    .build();

            when(reviewService.createReview(any(ReviewRequest.class)))
                    .thenReturn(reviewResponse);

            mockMvc.perform(post("/api/v1/reviews")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(objectMapper.writeValueAsString(request)))
                    .andExpect(status().isCreated())
                    .andExpect(jsonPath("$.id").exists())
                    .andExpect(jsonPath("$.title").value("Annual Performance Review 2024"))
                    .andExpect(jsonPath("$.status").value("DRAFT"));

            verify(reviewService).createReview(any(ReviewRequest.class));
        }

        @Test
        @DisplayName("Should return 400 for invalid review request")
        void shouldReturn400ForInvalidRequest() throws Exception {
            ReviewRequest request = new ReviewRequest();
            // Missing required fields

            mockMvc.perform(post("/api/v1/reviews")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(objectMapper.writeValueAsString(request)))
                    .andExpect(status().isBadRequest());
        }

        @Test
        @DisplayName("Should return 400 when employee ID is missing")
        void shouldReturn400WhenEmployeeIdMissing() throws Exception {
            ReviewRequest request = ReviewRequest.builder()
                    .reviewerId(reviewerId)
                    .title("Annual Performance Review 2024")
                    .build();

            mockMvc.perform(post("/api/v1/reviews")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(objectMapper.writeValueAsString(request)))
                    .andExpect(status().isBadRequest());
        }
    }

    @Nested
    @DisplayName("Review Retrieval Tests")
    class ReviewRetrievalTests {

        @Test
        @DisplayName("Should get all reviews with pagination")
        void shouldGetAllReviews() throws Exception {
            Page<ReviewResponse> page = new PageImpl<>(
                    Collections.singletonList(reviewResponse),
                    PageRequest.of(0, 20),
                    1
            );

            when(reviewService.getAllReviews(any(Pageable.class)))
                    .thenReturn(page);

            mockMvc.perform(get("/api/v1/reviews")
                    .param("page", "0")
                    .param("size", "20"))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.content", hasSize(1)))
                    .andExpect(jsonPath("$.content[0].title").value("Annual Performance Review 2024"));

            verify(reviewService).getAllReviews(any(Pageable.class));
        }

        @Test
        @DisplayName("Should get review by ID")
        void shouldGetReviewById() throws Exception {
            when(reviewService.getReviewById(reviewId))
                    .thenReturn(reviewResponse);

            mockMvc.perform(get("/api/v1/reviews/{id}", reviewId))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.id").value(reviewId.toString()))
                    .andExpect(jsonPath("$.title").value("Annual Performance Review 2024"));

            verify(reviewService).getReviewById(reviewId);
        }

        @Test
        @DisplayName("Should get employee reviews")
        void shouldGetEmployeeReviews() throws Exception {
            List<ReviewResponse> reviews = Collections.singletonList(reviewResponse);

            when(reviewService.getEmployeeReviews(employeeId))
                    .thenReturn(reviews);

            mockMvc.perform(get("/api/v1/reviews/employee/{employeeId}", employeeId))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$", hasSize(1)))
                    .andExpect(jsonPath("$[0].employeeId").value(employeeId.toString()));

            verify(reviewService).getEmployeeReviews(employeeId);
        }

        @Test
        @DisplayName("Should get employee reviews with pagination")
        void shouldGetEmployeeReviewsPaged() throws Exception {
            Page<ReviewResponse> page = new PageImpl<>(
                    Collections.singletonList(reviewResponse),
                    PageRequest.of(0, 20),
                    1
            );

            when(reviewService.getEmployeeReviewsPaged(eq(employeeId), any(Pageable.class)))
                    .thenReturn(page);

            mockMvc.perform(get("/api/v1/reviews/employee/{employeeId}/paged", employeeId)
                    .param("page", "0")
                    .param("size", "20"))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.content", hasSize(1)));

            verify(reviewService).getEmployeeReviewsPaged(eq(employeeId), any(Pageable.class));
        }

        @Test
        @DisplayName("Should get pending reviews for reviewer")
        void shouldGetPendingReviews() throws Exception {
            List<ReviewResponse> reviews = Collections.singletonList(reviewResponse);

            when(reviewService.getPendingReviews(reviewerId))
                    .thenReturn(reviews);

            mockMvc.perform(get("/api/v1/reviews/pending/{reviewerId}", reviewerId))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$", hasSize(1)));

            verify(reviewService).getPendingReviews(reviewerId);
        }

        @Test
        @DisplayName("Should get pending reviews for reviewer with pagination")
        void shouldGetPendingReviewsPaged() throws Exception {
            Page<ReviewResponse> page = new PageImpl<>(
                    Collections.singletonList(reviewResponse),
                    PageRequest.of(0, 20),
                    1
            );

            when(reviewService.getPendingReviewsPaged(eq(reviewerId), any(Pageable.class)))
                    .thenReturn(page);

            mockMvc.perform(get("/api/v1/reviews/pending/{reviewerId}/paged", reviewerId)
                    .param("page", "0")
                    .param("size", "20"))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.content", hasSize(1)));

            verify(reviewService).getPendingReviewsPaged(eq(reviewerId), any(Pageable.class));
        }
    }

    @Nested
    @DisplayName("Review Update Tests")
    class ReviewUpdateTests {

        @Test
        @DisplayName("Should update review successfully")
        void shouldUpdateReviewSuccessfully() throws Exception {
            ReviewRequest request = ReviewRequest.builder()
                    .employeeId(employeeId)
                    .reviewerId(reviewerId)
                    .title("Updated Review Title")
                    .reviewType("ANNUAL")
                    .build();

            ReviewResponse updatedResponse = reviewResponse.toBuilder()
                    .title("Updated Review Title")
                    .build();

            when(reviewService.updateReview(eq(reviewId), any(ReviewRequest.class)))
                    .thenReturn(updatedResponse);

            mockMvc.perform(put("/api/v1/reviews/{id}", reviewId)
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(objectMapper.writeValueAsString(request)))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.title").value("Updated Review Title"));

            verify(reviewService).updateReview(eq(reviewId), any(ReviewRequest.class));
        }

        @Test
        @DisplayName("Should submit review successfully")
        void shouldSubmitReviewSuccessfully() throws Exception {
            ReviewResponse submittedResponse = reviewResponse.toBuilder()
                    .status("SUBMITTED")
                    .build();

            when(reviewService.submitReview(reviewId))
                    .thenReturn(submittedResponse);

            mockMvc.perform(put("/api/v1/reviews/{id}/submit", reviewId))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.status").value("SUBMITTED"));

            verify(reviewService).submitReview(reviewId);
        }

        @Test
        @DisplayName("Should complete review successfully")
        void shouldCompleteReviewSuccessfully() throws Exception {
            ReviewResponse completedResponse = reviewResponse.toBuilder()
                    .status("COMPLETED")
                    .build();

            when(reviewService.completeReview(reviewId))
                    .thenReturn(completedResponse);

            mockMvc.perform(put("/api/v1/reviews/{id}/complete", reviewId))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.status").value("COMPLETED"));

            verify(reviewService).completeReview(reviewId);
        }
    }

    @Nested
    @DisplayName("Competency Tests")
    class CompetencyTests {

        @Test
        @DisplayName("Should add competency to review successfully")
        void shouldAddCompetencySuccessfully() throws Exception {
            CompetencyRequest request = CompetencyRequest.builder()
                    .reviewId(reviewId)
                    .competencyName("Leadership")
                    .rating(5)
                    .feedback("Excellent leadership skills")
                    .build();

            when(reviewService.addCompetency(any(CompetencyRequest.class)))
                    .thenReturn(competencyResponse);

            mockMvc.perform(post("/api/v1/reviews/competencies")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(objectMapper.writeValueAsString(request)))
                    .andExpect(status().isCreated())
                    .andExpect(jsonPath("$.competencyName").value("Leadership"))
                    .andExpect(jsonPath("$.rating").value(5));

            verify(reviewService).addCompetency(any(CompetencyRequest.class));
        }

        @Test
        @DisplayName("Should return 400 for invalid competency request")
        void shouldReturn400ForInvalidCompetencyRequest() throws Exception {
            CompetencyRequest request = new CompetencyRequest();
            // Missing required fields

            mockMvc.perform(post("/api/v1/reviews/competencies")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(objectMapper.writeValueAsString(request)))
                    .andExpect(status().isBadRequest());
        }

        @Test
        @DisplayName("Should get competencies for review")
        void shouldGetCompetencies() throws Exception {
            List<CompetencyResponse> competencies = Collections.singletonList(competencyResponse);

            when(reviewService.getCompetencies(reviewId))
                    .thenReturn(competencies);

            mockMvc.perform(get("/api/v1/reviews/{reviewId}/competencies", reviewId))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$", hasSize(1)))
                    .andExpect(jsonPath("$[0].competencyName").value("Leadership"));

            verify(reviewService).getCompetencies(reviewId);
        }
    }

    @Nested
    @DisplayName("Pagination Tests")
    class PaginationTests {

        @Test
        @DisplayName("Should handle pagination with custom sort order")
        void shouldHandlePaginationWithCustomSort() throws Exception {
            Page<ReviewResponse> page = new PageImpl<>(
                    Collections.singletonList(reviewResponse),
                    PageRequest.of(0, 20),
                    1
            );

            when(reviewService.getAllReviews(any(Pageable.class)))
                    .thenReturn(page);

            mockMvc.perform(get("/api/v1/reviews")
                    .param("page", "0")
                    .param("size", "20")
                    .param("sortBy", "createdAt")
                    .param("sortDirection", "DESC"))
                    .andExpect(status().isOk())
                    .andExpect(jsonPath("$.totalElements").value(1));

            verify(reviewService).getAllReviews(any(Pageable.class));
        }

        @Test
        @DisplayName("Should default to descending sort when invalid direction provided")
        void shouldDefaultToDescendingSort() throws Exception {
            Page<ReviewResponse> page = new PageImpl<>(
                    Collections.singletonList(reviewResponse),
                    PageRequest.of(0, 20),
                    1
            );

            when(reviewService.getAllReviews(any(Pageable.class)))
                    .thenReturn(page);

            mockMvc.perform(get("/api/v1/reviews")
                    .param("sortDirection", "INVALID"))
                    .andExpect(status().isOk());

            verify(reviewService).getAllReviews(any(Pageable.class));
        }
    }
}
