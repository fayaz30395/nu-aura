# HRMS Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control

# Database Configuration
# For local development (Docker/local PostgreSQL):
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hrms
SPRING_DATASOURCE_USERNAME=hrms
SPRING_DATASOURCE_PASSWORD=your_local_password

# For Neon cloud database (used by docker-compose):
# Get your Neon connection string from: https://console.neon.tech/app/projects
# Use the pooling endpoint (includes "-pooler" in hostname)
NEON_JDBC_URL=jdbc:postgresql://your-endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require
NEON_DB_USERNAME=neondb_owner
NEON_DB_PASSWORD=your_neon_password

# Flyway migrations (optional - defaults to main datasource)
# For Neon, use non-pooler endpoint: jdbc:postgresql://ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# FLYWAY_URL=
# FLYWAY_USER=
# FLYWAY_PASSWORD=

# Redis Configuration
DEV_REDIS_HOST=localhost
DEV_REDIS_PORT=6379

# JWT Configuration (REQUIRED - must be at least 256 bits / 32 characters)
JWT_SECRET=your-secure-jwt-secret-must-be-at-least-256-bits-long-for-production

# MinIO / Object Storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=hrms-files

# Email Configuration
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI / LLM Configuration (default: Groq free tier — OpenAI-compatible)
# Sign up at https://groq.com for a free API key
OPENAI_API_KEY=your_groq_or_openai_api_key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant
