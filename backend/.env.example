# HRMS Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control

# Database Configuration
DEV_DATABASE_URL=jdbc:postgresql://localhost:5432/hrms_dev
DEV_DATABASE_USERNAME=hrms_user
DEV_DATABASE_PASSWORD=your_secure_password_here

# Redis Configuration
DEV_REDIS_HOST=localhost
DEV_REDIS_PORT=6379

# JWT Configuration (REQUIRED - must be at least 256 bits / 32 characters)
JWT_SECRET=your-secure-jwt-secret-must-be-at-least-256-bits-long-for-production

# MinIO / Object Storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=hrms-files

# Email Configuration
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI / LLM Configuration (default: Groq free tier — OpenAI-compatible)
# Sign up at https://groq.com for a free API key
OPENAI_API_KEY=your_groq_or_openai_api_key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant
