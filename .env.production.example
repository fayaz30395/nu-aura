# ============================================================
# NU-AURA HRMS — Production Environment Variables
# ============================================================
# Copy this file to .env (DO NOT commit .env)
# Every variable marked REQUIRED must be set before starting the application.
# Missing REQUIRED variables will cause startup failure.
# ============================================================

# ─── Spring Profile ───────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod            # REQUIRED: use 'prod' in production; 'demo' adds seed data

# ─── Database ─────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/hrms       # REQUIRED
SPRING_DATASOURCE_USERNAME=hrms_user                       # REQUIRED
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_strong_db_password    # REQUIRED

DB_POOL_MAX=20           # optional; default 20
DB_POOL_MIN=5            # optional; default 5

# ─── Redis ────────────────────────────────────────────────────────────────────
SPRING_REDIS_HOST=redis                # REQUIRED (AccountLockoutService + caching depend on Redis)
SPRING_REDIS_PORT=6379                 # optional; default 6379
SPRING_REDIS_PASSWORD=                 # REQUIRED if Redis auth is enabled
SPRING_REDIS_SSL_ENABLED=false         # set true if Redis uses TLS

# ─── JWT (Authentication) ─────────────────────────────────────────────────────
# REQUIRED: 32+ byte random string. App will REFUSE to start if this is missing.
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRATION=3600000           # optional; default 1 hour (ms)
JWT_REFRESH_EXPIRATION=86400000  # optional; default 24 hours (ms)

# ─── Encryption (AES-256-GCM for sensitive fields) ────────────────────────────
# REQUIRED: exactly 32 bytes (256 bits). Generate with: openssl rand -base64 32
APP_SECURITY_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# ─── MinIO (File Storage) ─────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000       # REQUIRED
MINIO_ACCESS_KEY=CHANGE_ME             # REQUIRED
MINIO_SECRET_KEY=CHANGE_ME             # REQUIRED
MINIO_BUCKET=hrms-files                # optional; default hrms-files

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.yourprovider.com        # REQUIRED for email notifications
MAIL_PORT=587                          # optional; default 587
MAIL_USERNAME=noreply@yourdomain.com   # REQUIRED
MAIL_PASSWORD=CHANGE_ME                # REQUIRED
MAIL_FROM=noreply@yourdomain.com       # optional

# ─── Google OAuth (Social Login) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=                      # optional; required for Google SSO
GOOGLE_CLIENT_SECRET=                  # optional; required for Google SSO

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.yourdomain.com  # REQUIRED: used for CORS + email links
COOKIE_SECURE=true                       # REQUIRED: must be true with HTTPS
COOKIE_DOMAIN=.yourdomain.com            # optional; set for cross-subdomain auth

# ─── CSRF ─────────────────────────────────────────────────────────────────────
CSRF_ENABLED=true                      # REQUIRED: must be true in production

# ─── Tenant Resolution ────────────────────────────────────────────────────────
TENANT_RESOLUTION_STRATEGY=header      # optional; header | subdomain

# ─── Server Error Verbosity ───────────────────────────────────────────────────
SERVER_ERROR_INCLUDE_MESSAGE=never     # REQUIRED: never in production (prevents info leak)
SERVER_ERROR_INCLUDE_BINDING=never     # REQUIRED: never in production

# ─── Twilio SMS (optional) ────────────────────────────────────────────────────
TWILIO_MOCK_MODE=true                  # set false + provide credentials for real SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Calendar Integration (optional) ─────────────────────────────────────────
CALENDAR_MOCK_MODE=true                # set false + provide credentials for real calendar sync
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# ─── AI / OpenAI (optional, for ATS resume parsing) ──────────────────────────
OPENAI_API_KEY=                        # optional; leave empty to disable AI features
OPENAI_MODEL=gpt-4o-mini

# ─── Observability ────────────────────────────────────────────────────────────
SLOW_QUERY_THRESHOLD_MS=200            # optional; default 200ms
HIBERNATE_STATS_ENABLED=false          # optional; enable for performance profiling

# ─── Slack Notifications (optional) ──────────────────────────────────────────
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# ─── Auth Domain Restriction ──────────────────────────────────────────────────
AUTH_ALLOWED_DOMAIN=yourdomain.com     # optional; restricts registration to this email domain

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_CAPACITY=10
RATE_LIMIT_API_CAPACITY=100
RATE_LIMIT_EXPORT_CAPACITY=5

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com   # REQUIRED
NEXT_PUBLIC_GOOGLE_CLIENT_ID=                    # optional; required for Google SSO on frontend
NEXT_PUBLIC_DEMO_MODE=false                      # set true to show demo credentials on login
