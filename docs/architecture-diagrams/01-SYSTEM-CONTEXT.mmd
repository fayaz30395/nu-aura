%% ============================================================================
%% NU-AURA HRMS - System Context Diagram (C4 Level 1)
%% FOR BUSINESS STAKEHOLDERS
%%
%% HOW TO USE:
%% 1. Copy this entire file content
%% 2. Go to https://mermaid.live
%% 3. Paste and export as PNG/SVG for presentations
%% ============================================================================

graph TB
    %% Define main system
    HRMS[("<b>NU-AURA HRMS</b><br/>Multi-Tenant Cloud Platform<br/><br/>Comprehensive HR Management System<br/>• Employee Lifecycle Management<br/>• Payroll & Compensation<br/>• Performance Management<br/>• Recruitment & Onboarding<br/>• Learning & Development<br/>• Time & Attendance")]

    %% Define user personas
    ADMIN[("<b>System Admin</b><br/>Platform & tenant configuration")]
    HR[("<b>HR Team</b><br/>Employee management,<br/>recruitment, payroll")]
    MANAGER[("<b>Managers</b><br/>Team management,<br/>approvals, performance")]
    EMPLOYEE[("<b>Employees</b><br/>Self-service,<br/>timesheets, leaves")]
    CANDIDATE[("<b>Candidates</b><br/>Job applications,<br/>offer acceptance")]

    %% Define external systems
    EMAIL[("<b>Email Providers</b><br/>Gmail, Outlook, SendGrid<br/><br/>• Notifications<br/>• Alerts<br/>• Reports")]
    SLACK[("<b>Slack / Teams</b><br/><br/>• Team notifications<br/>• Approvals<br/>• Bot interactions")]
    JOB_BOARDS[("<b>Job Boards</b><br/>LinkedIn, Indeed, Naukri<br/><br/>• Job postings<br/>• Candidate sourcing<br/>• Application tracking")]
    BANKING[("<b>Banking Systems</b><br/><br/>• Payroll disbursement<br/>• Salary transfers<br/>• Payment processing")]
    SSO[("<b>SSO Providers</b><br/>Okta, Azure AD, Google<br/><br/>• Single Sign-On<br/>• Enterprise authentication")]
    STORAGE[("<b>Cloud Storage</b><br/>AWS S3, Azure Blob<br/><br/>• Documents<br/>• Resumes<br/>• Payslips")]
    GOV[("<b>Govt. Portals</b><br/>PF, ESI, Tax<br/><br/>• Statutory compliance<br/>• Filings<br/>• Reports")]
    ANALYTICS[("<b>BI Tools</b><br/>Tableau, Power BI<br/><br/>• Advanced analytics<br/>• Custom dashboards")]

    %% User connections
    ADMIN -->|Manages tenants,<br/>configures system| HRMS
    HR -->|Manages employees,<br/>runs payroll| HRMS
    MANAGER -->|Approves requests,<br/>reviews performance| HRMS
    EMPLOYEE -->|Submits leaves,<br/>views payslips| HRMS
    CANDIDATE -->|Applies for jobs,<br/>accepts offers| HRMS

    %% External system connections
    HRMS -->|Sends notifications| EMAIL
    HRMS -->|Posts updates| SLACK
    HRMS -->|Posts jobs,<br/>syncs applications| JOB_BOARDS
    HRMS -->|Initiates payments| BANKING
    HRMS -->|Authenticates users| SSO
    HRMS -->|Stores/retrieves files| STORAGE
    HRMS -->|Submits filings| GOV
    HRMS -->|Exports data| ANALYTICS

    %% Styling
    classDef systemStyle fill:#465fff,stroke:#2a31d8,stroke-width:3px,color:#fff
    classDef userStyle fill:#12b76a,stroke:#0a9960,stroke-width:2px,color:#fff
    classDef externalStyle fill:#f79009,stroke:#dc6803,stroke-width:2px,color:#fff

    class HRMS systemStyle
    class ADMIN,HR,MANAGER,EMPLOYEE,CANDIDATE userStyle
    class EMAIL,SLACK,JOB_BOARDS,BANKING,SSO,STORAGE,GOV,ANALYTICS externalStyle

    %% Notes
    note1[/"<b>KEY BENEFITS</b><br/>✓ Single platform for all HR needs<br/>✓ 60+ integrated modules<br/>✓ Multi-tenant SaaS architecture<br/>✓ Enterprise-grade security"/]

    style note1 fill:#f9fafb,stroke:#475467,stroke-width:1px,color:#101828
