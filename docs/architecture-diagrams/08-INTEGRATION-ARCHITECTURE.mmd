graph TB
    %% Core HRMS System
    HRMS[("<b>NU-AURA HRMS</b><br/>Core Platform")]

    %% SSO & Authentication
    subgraph SSO_GROUP["<b>🔐 AUTHENTICATION & SSO</b>"]
        OKTA[("<b>Okta</b><br/>• SAML 2.0<br/>• OAuth 2.0 + OIDC<br/>• User provisioning (SCIM)<br/>• Auto-sync employees")]

        AZURE_AD[("<b>Azure AD</b><br/>• SAML SSO<br/>• OAuth 2.0<br/>• Directory sync<br/>• Group mapping")]

        GOOGLE_SSO[("<b>Google Workspace</b><br/>• OAuth 2.0<br/>• G Suite integration<br/>• Calendar sync<br/>• Email integration")]

        GENERIC_SAML[("<b>Generic SAML</b><br/>• Any SAML 2.0 provider<br/>• Custom attribute mapping<br/>• JIT provisioning")]
    end

    %% Communication
    subgraph COMM_GROUP["<b>📧 COMMUNICATION</b>"]
        SENDGRID[("<b>SendGrid</b><br/>• Transactional emails<br/>• Payslip delivery<br/>• Offer letters<br/>• Notifications<br/><br/>API: SMTP + REST")]

        SLACK[("<b>Slack</b><br/>• Channel notifications<br/>• Approval bot<br/>• Leave alerts<br/>• Payroll reminders<br/><br/>API: Webhooks + Events API")]

        MS_TEAMS[("<b>Microsoft Teams</b><br/>• Team notifications<br/>• Bot interactions<br/>• Calendar integration<br/><br/>API: Graph API")]

        TWILIO[("<b>Twilio</b><br/>• SMS notifications<br/>• OTP delivery<br/>• Emergency alerts<br/><br/>API: REST")]
    end

    %% Job Boards
    subgraph JOB_BOARDS["<b>🎯 JOB BOARDS & ATS</b>"]
        LINKEDIN[("<b>LinkedIn Talent</b><br/>• Job posting<br/>• Candidate sourcing<br/>• Application tracking<br/>• InMail messaging<br/><br/>API: REST + OAuth 2.0")]

        INDEED[("<b>Indeed</b><br/>• Job posting<br/>• Application feed<br/>• Sponsored listings<br/><br/>API: XML Feed + REST")]

        NAUKRI[("<b>Naukri</b><br/>• Job posting<br/>• Resume database access<br/>• Application tracking<br/><br/>API: REST")]

        GLASSDOOR[("<b>Glassdoor</b><br/>• Company reviews<br/>• Salary insights<br/>• Job posting<br/><br/>API: REST")]
    end

    %% Payroll & Finance
    subgraph FINANCE_GROUP["<b>💰 PAYROLL & FINANCE</b>"]
        RAZORPAY[("<b>Razorpay</b><br/>• Salary disbursement<br/>• Bulk transfers<br/>• Payment status tracking<br/><br/>API: REST + Webhooks")]

        STRIPE[("<b>Stripe</b><br/>• International payroll<br/>• Multi-currency<br/>• Payment links<br/><br/>API: REST")]

        BANK_API[("<b>Bank APIs</b><br/>• NEFT/RTGS/IMPS<br/>• Account verification<br/>• Transaction status<br/><br/>API: SFTP + REST")]

        XERO[("<b>Xero</b><br/>• Accounting sync<br/>• Payroll journals<br/>• Expense tracking<br/><br/>API: OAuth 2.0 + REST")]
    end

    %% Government & Compliance
    subgraph GOV_GROUP["<b>🏛️ GOVERNMENT & COMPLIANCE</b>"]
        EPFO[("<b>EPFO Portal</b><br/>• PF contributions<br/>• ECR generation<br/>• UAN management<br/><br/>API: File upload + Scraping")]

        ESIC[("<b>ESIC Portal</b><br/>• ESI contributions<br/>• Challan generation<br/>• Employee registration<br/><br/>API: File upload")]

        TAX_PORTAL[("<b>Tax Portal</b><br/>• TDS filing<br/>• Form 16 generation<br/>• Challan payment<br/><br/>API: File upload + REST")]

        PT_PORTAL[("<b>Professional Tax</b><br/>• PT deduction<br/>• State-wise compliance<br/>• Challan generation<br/><br/>API: File upload")]
    end

    %% Storage & Documents
    subgraph STORAGE_GROUP["<b>☁️ STORAGE & DOCUMENTS</b>"]
        AWS_S3[("<b>AWS S3</b><br/>• Resumes<br/>• Documents<br/>• Payslips<br/>• Profile pictures<br/><br/>API: AWS SDK")]

        GOOGLE_DRIVE[("<b>Google Drive</b><br/>• Document storage<br/>• Shared folders<br/>• Real-time collab<br/><br/>API: Drive API")]

        DOCUSIGN[("<b>DocuSign</b><br/>• Offer letter signing<br/>• Contract signing<br/>• NDA signing<br/><br/>API: REST + Webhooks")]
    end

    %% Analytics & BI
    subgraph ANALYTICS_GROUP["<b>📊 ANALYTICS & BI</b>"]
        TABLEAU[("<b>Tableau</b><br/>• Custom dashboards<br/>• Data extract<br/>• Advanced analytics<br/><br/>API: REST + Embed API")]

        POWER_BI[("<b>Power BI</b><br/>• Executive dashboards<br/>• Data export<br/>• Real-time refresh<br/><br/>API: REST")]

        GOOGLE_ANALYTICS[("<b>Google Analytics</b><br/>• User behavior tracking<br/>• Feature usage<br/>• Performance monitoring<br/><br/>API: Measurement Protocol")]
    end

    %% Background Verification
    subgraph BGV_GROUP["<b>🔍 BACKGROUND VERIFICATION</b>"]
        SPRINGVERIFY[("<b>SpringVerify</b><br/>• Identity verification<br/>• Education check<br/>• Employment check<br/>• Criminal record check<br/><br/>API: REST + Webhooks")]

        AUTHBRIDGE[("<b>AuthBridge</b><br/>• Comprehensive BGV<br/>• Court record search<br/>• Address verification<br/><br/>API: REST")]
    end

    %% HRIS Sync
    subgraph HRIS_GROUP["<b>🔄 LEGACY HRIS SYNC</b>"]
        SAP[("<b>SAP SuccessFactors</b><br/>• Employee master sync<br/>• Org hierarchy import<br/>• Bidirectional sync<br/><br/>API: OData + SOAP")]

        WORKDAY[("<b>Workday</b><br/>• Employee data sync<br/>• Position import<br/>• Compensation sync<br/><br/>API: REST + SOAP")]

        ORACLE_HCM[("<b>Oracle HCM Cloud</b><br/>• Master data sync<br/>• Payroll integration<br/><br/>API: REST + SOAP")]
    end

    %% Connections
    HRMS -->|SAML/OAuth| SSO_GROUP
    HRMS -->|REST/SMTP| COMM_GROUP
    HRMS -->|REST APIs| JOB_BOARDS
    HRMS -->|REST APIs + Webhooks| FINANCE_GROUP
    HRMS -->|File Upload + REST| GOV_GROUP
    HRMS -->|SDK/APIs| STORAGE_GROUP
    HRMS -->|Data Export + Embed| ANALYTICS_GROUP
    HRMS -->|REST + Webhooks| BGV_GROUP
    HRMS -->|Bidirectional Sync| HRIS_GROUP

    %% Webhook listeners
    RAZORPAY -.->|Webhooks<br/>payment.success| HRMS
    STRIPE -.->|Webhooks<br/>transfer.updated| HRMS
    DOCUSIGN -.->|Webhooks<br/>envelope.completed| HRMS
    LINKEDIN -.->|Webhooks<br/>application.created| HRMS
    SLACK -.->|Events API<br/>message.posted| HRMS
    SPRINGVERIFY -.->|Webhooks<br/>verification.completed| HRMS

