%% 10. SECURITY ARCHITECTURE LAYERS
graph TB
    subgraph "Layer 1: Edge Security - Next.js Middleware"
        L1A[OWASP Security Headers<br/>X-Frame-Options: DENY<br/>X-Content-Type-Options: nosniff<br/>HSTS, CSP, Referrer-Policy]
        L1B[Coarse JWT Decode<br/>Base64 decode, no signature verification]
        L1C[Route Protection<br/>16 public routes, 47+ auth routes]
    end

    subgraph "Layer 2: Network Security - Spring Security"
        L2A[CORS Configuration<br/>Explicit origins, no wildcards]
        L2B[CSRF Protection<br/>Double-submit cookie pattern]
        L2C[Security Headers Backend<br/>Defense in depth - same headers as edge]
    end

    subgraph "Layer 3: Authentication - TenantFilter + JwtAuthenticationFilter"
        L3A[Tenant Extraction<br/>X-Tenant-ID from JWT claim]
        L3B[JWT Validation<br/>JJWT 0.12.6, signature verification]
        L3C[Permission Loading<br/>Redis cache, 1-hour TTL]
    end

    subgraph "Layer 4: Authorization - PermissionAspect"
        L4A[@RequiresPermission<br/>AOP aspect, checks SecurityContext]
        L4B[SuperAdmin Bypass<br/>SUPER_ADMIN role bypasses all checks]
        L4C[Permission Hierarchy<br/>MODULE:MANAGE implies all sub-permissions]
    end

    subgraph "Layer 5: Data Access - Repository + RLS"
        L5A[Repository Query Filter<br/>All queries include tenant_id]
        L5B[PostgreSQL RLS<br/>Row-Level Security policies]
        L5C[Audit Logging<br/>JSONB old_values, new_values]
    end

    subgraph "Layer 6: Rate Limiting - Bucket4j"
        L6A[Token Bucket Algorithm<br/>5/min auth, 100/min API, 5/5min exports]
        L6B[Redis-backed State<br/>Distributed rate limiting]
        L6C[Graceful Degradation<br/>Fallback to in-memory if Redis down]
    end

    L1A --> L1B --> L1C
    L1C --> L2A --> L2B --> L2C
    L2C --> L3A --> L3B --> L3C
    L3C --> L4A --> L4B --> L4C
    L4C --> L5A --> L5B --> L5C
    L3A --> L6A --> L6B --> L6C

