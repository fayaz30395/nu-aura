%% ============================================================================
%% NU-AURA HRMS - Container Diagram (C4 Level 2)
%% TECHNOLOGY STACK & DEPLOYMENT
%%
%% Render at: https://mermaid.live
%% ============================================================================

graph TB
    %% Users
    WEB_USER[("<b>Web Users</b><br/>Browsers")]
    MOBILE_USER[("<b>Mobile Users</b><br/>iOS/Android")]
    API_CLIENT[("<b>API Clients</b><br/>3rd party integrations")]

    %% Frontend Layer
    subgraph FRONTEND["<b>FRONTEND LAYER</b>"]
        NEXTJS[("<b>Next.js 14 App</b><br/>React 18, TypeScript<br/><br/>• App Router (SSR/SSG)<br/>• Mantine UI Components<br/>• React Query (caching)<br/>• Zustand (state mgmt)<br/><br/>Port: 3000")]

        PWA[("<b>Progressive Web App</b><br/><br/>• Offline support<br/>• Mobile optimized<br/>• Push notifications")]
    end

    %% Backend Layer
    subgraph BACKEND["<b>BACKEND LAYER</b>"]
        SPRING[("<b>Spring Boot 3.4.1</b><br/>Java 17, Maven<br/><br/>• REST APIs<br/>• JWT Authentication<br/>• RBAC Authorization<br/>• Multi-tenant isolation<br/><br/>Port: 8080")]

        ASYNC[("<b>Async Workers</b><br/><br/>• Email notifications<br/>• Payroll processing<br/>• Report generation<br/>• File exports")]

        SCHEDULER[("<b>Job Scheduler</b><br/>Spring @Scheduled<br/><br/>• Leave accrual (monthly)<br/>• Job board sync (6hr)<br/>• Webhook retries (1min)")]
    end

    %% Data Layer
    subgraph DATA["<b>DATA LAYER</b>"]
        POSTGRES[("<b>PostgreSQL 14</b><br/><br/>• Primary database<br/>• Row-level security (RLS)<br/>• JSONB for flexibility<br/>• Full-text search<br/><br/>Port: 5432")]

        REDIS[("<b>Redis 7</b><br/><br/>• Session cache<br/>• Permission cache (5min TTL)<br/>• Rate limiting<br/>• Real-time data<br/><br/>Port: 6379")]

        S3[("<b>Object Storage</b><br/>AWS S3 / MinIO<br/><br/>• Resumes<br/>• Documents<br/>• Payslips<br/>• Profile pictures")]
    end

    %% Event Streaming
    subgraph EVENTS["<b>EVENT STREAMING</b>"]
        KAFKA[("<b>Apache Kafka</b><br/><br/>• Leave approved events<br/>• Payroll completed events<br/>• Employee onboarded events<br/>• Workflow state changes<br/><br/>Port: 9092")]
    end

    %% Monitoring & Observability
    subgraph OBSERVABILITY["<b>OBSERVABILITY</b>"]
        PROMETHEUS[("<b>Prometheus</b><br/><br/>• Metrics collection<br/>• Connection pool stats<br/>• API latency tracking")]

        GRAFANA[("<b>Grafana</b><br/><br/>• Dashboards<br/>• Alerts<br/>• Visualizations")]

        LOGS[("<b>ELK Stack</b><br/>Elasticsearch, Logstash, Kibana<br/><br/>• Centralized logging<br/>• Audit trail<br/>• Error tracking")]
    end

    %% External Services
    subgraph EXTERNAL["<b>EXTERNAL SERVICES</b>"]
        SMTP[("<b>Email Gateway</b><br/>SendGrid/AWS SES")]
        SLACK_API[("<b>Slack API</b>")]
        JOB_API[("<b>Job Board APIs</b><br/>LinkedIn, Indeed")]
        PAYMENT[("<b>Payment Gateway</b><br/>Razorpay, Stripe")]
    end

    %% Connections - Users to Frontend
    WEB_USER -->|HTTPS| NEXTJS
    MOBILE_USER -->|HTTPS| PWA
    API_CLIENT -->|HTTPS<br/>API Key Auth| SPRING

    %% Connections - Frontend to Backend
    NEXTJS -->|REST API<br/>JWT Bearer Token| SPRING
    PWA -->|REST API<br/>JWT Bearer Token| SPRING

    %% Connections - Backend to Data
    SPRING -->|JDBC<br/>Hikari Pool (25 conn)| POSTGRES
    SPRING -->|Lettuce Client| REDIS
    SPRING -->|AWS SDK / MinIO Client| S3
    ASYNC -->|Reads/Writes| POSTGRES
    SCHEDULER -->|Reads/Writes| POSTGRES

    %% Connections - Event Streaming
    SPRING -->|Produces events| KAFKA
    SPRING -->|Consumes events| KAFKA
    ASYNC -->|Consumes events| KAFKA

    %% Connections - Backend to External
    SPRING -->|SMTP| SMTP
    SPRING -->|REST API| SLACK_API
    SPRING -->|REST API| JOB_API
    SPRING -->|REST API| PAYMENT

    %% Connections - Monitoring
    SPRING -->|Exposes /actuator/prometheus| PROMETHEUS
    POSTGRES -->|Metrics| PROMETHEUS
    REDIS -->|Metrics| PROMETHEUS
    PROMETHEUS -->|Data source| GRAFANA
    SPRING -->|Logs (JSON)| LOGS

    %% Styling
    classDef frontendStyle fill:#465fff,stroke:#2a31d8,stroke-width:2px,color:#fff
    classDef backendStyle fill:#12b76a,stroke:#0a9960,stroke-width:2px,color:#fff
    classDef dataStyle fill:#f79009,stroke:#dc6803,stroke-width:2px,color:#fff
    classDef externalStyle fill:#667085,stroke:#475467,stroke-width:2px,color:#fff
    classDef obsStyle fill:#7886ff,stroke:#5b6fff,stroke-width:2px,color:#fff

    class NEXTJS,PWA frontendStyle
    class SPRING,ASYNC,SCHEDULER backendStyle
    class POSTGRES,REDIS,S3,KAFKA dataStyle
    class SMTP,SLACK_API,JOB_API,PAYMENT externalStyle
    class PROMETHEUS,GRAFANA,LOGS obsStyle
