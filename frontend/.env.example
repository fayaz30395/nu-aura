# NU-AURA HRMS Frontend Environment Configuration
# Copy this file to .env.local and configure values for your environment
# See lib/config/env.ts for validation rules

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Backend API URL (required)
# The base URL for the HRMS backend API
# Development: http://localhost:8080/api/v1
# Production: https://api.your-domain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Google OAuth Client ID (optional)
# Required for Google social login functionality
# Get from: https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Demo Mode (optional)
# Set to 'true' to show demo credentials on login page
# Default: 'false' (disabled in production)
NEXT_PUBLIC_DEMO_MODE=false

# Payments Module (optional)
# Set to 'true' to show the Payments navigation and pages
# Default: 'false' (disabled — payment gateway integration not yet production-ready)
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Bundle Analyzer (development only)
# Set to 'true' to analyze bundle size during build
# Usage: ANALYZE=true npm run build
ANALYZE=false
