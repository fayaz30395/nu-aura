<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ANALYTICS MODULE -->
    <changeSet id="073-create-report-definitions-table" author="hrms">
        <createTable tableName="report_definitions">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="report_code" type="VARCHAR(50)"><constraints nullable="false" unique="true"/></column>
            <column name="report_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="category" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"/>
            <column name="query_template" type="TEXT"/>
            <column name="parameters" type="TEXT"/>
            <column name="output_format" type="VARCHAR(20)"/>
            <column name="is_system_report" type="BOOLEAN"/>
            <column name="is_active" type="BOOLEAN"><constraints nullable="false"/></column>
            <column name="access_level" type="VARCHAR(30)"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
        <createIndex tableName="report_definitions" indexName="idx_reports_tenant_category">
            <column name="tenant_id"/><column name="category"/>
        </createIndex>
    </changeSet>

    <changeSet id="073-create-scheduled-reports-table" author="hrms">
        <createTable tableName="scheduled_reports">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="report_definition_id" type="UUID"><constraints nullable="false"/></column>
            <column name="schedule_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="frequency" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="day_of_week" type="INTEGER"/>
            <column name="day_of_month" type="INTEGER"/>
            <column name="time_of_day" type="TIME"/>
            <column name="recipients" type="TEXT"/>
            <column name="parameters" type="TEXT"/>
            <column name="is_active" type="BOOLEAN"><constraints nullable="false"/></column>
            <column name="last_run_at" type="TIMESTAMP"/>
            <column name="next_run_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-report-executions-table" author="hrms">
        <createTable tableName="report_executions">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="report_definition_id" type="UUID"><constraints nullable="false"/></column>
            <column name="scheduled_report_id" type="UUID"/>
            <column name="executed_by" type="UUID"/>
            <column name="execution_type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="parameters" type="TEXT"/>
            <column name="status" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="file_path" type="VARCHAR(500)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="row_count" type="INTEGER"/>
            <column name="execution_time_ms" type="BIGINT"/>
            <column name="error_message" type="TEXT"/>
            <column name="started_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="completed_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-dashboards-table" author="hrms">
        <createTable tableName="dashboards">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="dashboard_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="dashboard_type" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"/>
            <column name="layout_config" type="TEXT"/>
            <column name="is_default" type="BOOLEAN"/>
            <column name="is_public" type="BOOLEAN"/>
            <column name="owner_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-dashboard-widgets-table" author="hrms">
        <createTable tableName="dashboard_widgets">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="dashboard_id" type="UUID"><constraints nullable="false"/></column>
            <column name="widget_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="widget_type" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="data_source" type="TEXT"/>
            <column name="configuration" type="TEXT"/>
            <column name="position_x" type="INTEGER"/>
            <column name="position_y" type="INTEGER"/>
            <column name="width" type="INTEGER"/>
            <column name="height" type="INTEGER"/>
            <column name="refresh_interval" type="INTEGER"/>
            <column name="is_visible" type="BOOLEAN"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-analytics-metrics-table" author="hrms">
        <createTable tableName="analytics_metrics">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="metric_name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="metric_category" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="metric_date" type="DATE"><constraints nullable="false"/></column>
            <column name="metric_value" type="DECIMAL(15,2)"><constraints nullable="false"/></column>
            <column name="dimension1" type="VARCHAR(100)"/>
            <column name="dimension2" type="VARCHAR(100)"/>
            <column name="dimension3" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="analytics_metrics" indexName="idx_metrics_tenant_date">
            <column name="tenant_id"/><column name="metric_date"/>
        </createIndex>
    </changeSet>

    <!-- DOCUMENT MANAGEMENT MODULE -->
    <changeSet id="073-create-document-templates-table" author="hrms">
        <createTable tableName="document_templates">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="template_code" type="VARCHAR(50)"><constraints nullable="false" unique="true"/></column>
            <column name="template_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="category" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"/>
            <column name="template_content" type="TEXT"/>
            <column name="placeholders" type="TEXT"/>
            <column name="file_name_pattern" type="VARCHAR(200)"/>
            <column name="is_system_template" type="BOOLEAN"/>
            <column name="is_active" type="BOOLEAN"><constraints nullable="false"/></column>
            <column name="requires_approval" type="BOOLEAN"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-generated-documents-table" author="hrms">
        <createTable tableName="generated_documents">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="template_id" type="UUID"><constraints nullable="false"/></column>
            <column name="employee_id" type="UUID"/>
            <column name="document_number" type="VARCHAR(50)"><constraints unique="true"/></column>
            <column name="file_path" type="VARCHAR(500)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="status" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="generated_data" type="TEXT"/>
            <column name="is_signed" type="BOOLEAN"/>
            <column name="signature_data" type="TEXT"/>
            <column name="valid_until" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-document-versions-table" author="hrms">
        <createTable tableName="document_versions">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="document_id" type="UUID"><constraints nullable="false"/></column>
            <column name="version_number" type="INTEGER"><constraints nullable="false"/></column>
            <column name="file_path" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="file_size" type="BIGINT"/>
            <column name="checksum" type="VARCHAR(64)"/>
            <column name="change_summary" type="TEXT"/>
            <column name="is_current" type="BOOLEAN"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="created_by" type="UUID"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-document-approvals-table" author="hrms">
        <createTable tableName="document_approvals">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="document_id" type="UUID"><constraints nullable="false"/></column>
            <column name="approver_id" type="UUID"><constraints nullable="false"/></column>
            <column name="approval_level" type="INTEGER"/>
            <column name="status" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="comments" type="TEXT"/>
            <column name="approved_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-document-categories-table" author="hrms">
        <createTable tableName="document_categories">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="category_code" type="VARCHAR(50)"><constraints nullable="false" unique="true"/></column>
            <column name="category_name" type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="parent_category_id" type="UUID"/>
            <column name="description" type="TEXT"/>
            <column name="retention_period_days" type="INTEGER"/>
            <column name="is_mandatory" type="BOOLEAN"/>
            <column name="requires_expiry_tracking" type="BOOLEAN"/>
            <column name="is_active" type="BOOLEAN"><constraints nullable="false"/></column>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
    </changeSet>

    <!-- AI/ML MODULE -->
    <changeSet id="073-create-resume-parsing-results-table" author="hrms">
        <createTable tableName="resume_parsing_results">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="candidate_id" type="UUID"/>
            <column name="job_application_id" type="UUID"/>
            <column name="file_path" type="VARCHAR(500)"/>
            <column name="parsed_data" type="TEXT"/>
            <column name="full_name" type="VARCHAR(200)"/>
            <column name="email" type="VARCHAR(200)"/>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="total_experience_years" type="INTEGER"/>
            <column name="skills" type="TEXT"/>
            <column name="education" type="TEXT"/>
            <column name="work_experience" type="TEXT"/>
            <column name="certifications" type="TEXT"/>
            <column name="confidence_score" type="DOUBLE"/>
            <column name="parsing_model" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="created_by" type="UUID"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-candidate-match-scores-table" author="hrms">
        <createTable tableName="candidate_match_scores">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="candidate_id" type="UUID"><constraints nullable="false"/></column>
            <column name="job_opening_id" type="UUID"><constraints nullable="false"/></column>
            <column name="overall_match_score" type="DOUBLE"><constraints nullable="false"/></column>
            <column name="skills_match_score" type="DOUBLE"/>
            <column name="experience_match_score" type="DOUBLE"/>
            <column name="education_match_score" type="DOUBLE"/>
            <column name="cultural_fit_score" type="DOUBLE"/>
            <column name="matching_criteria" type="TEXT"/>
            <column name="strengths" type="TEXT"/>
            <column name="gaps" type="TEXT"/>
            <column name="recommendation" type="VARCHAR(50)"/>
            <column name="ai_model_version" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-sentiment-analysis-table" author="hrms">
        <createTable tableName="sentiment_analysis">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="source_type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="source_id" type="UUID"><constraints nullable="false"/></column>
            <column name="text_content" type="TEXT"/>
            <column name="sentiment" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="sentiment_score" type="DOUBLE"/>
            <column name="confidence_score" type="DOUBLE"/>
            <column name="emotions" type="TEXT"/>
            <column name="key_phrases" type="TEXT"/>
            <column name="topics" type="TEXT"/>
            <column name="ai_model_version" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="073-create-attrition-predictions-table" author="hrms">
        <createTable tableName="attrition_predictions">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="employee_id" type="UUID"><constraints nullable="false"/></column>
            <column name="risk_score" type="DOUBLE"><constraints nullable="false"/></column>
            <column name="risk_level" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="contributing_factors" type="TEXT"/>
            <column name="recommended_actions" type="TEXT"/>
            <column name="prediction_date" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="actual_outcome" type="VARCHAR(20)"/>
            <column name="outcome_date" type="TIMESTAMP"/>
            <column name="ai_model_version" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-chatbot-conversations-table" author="hrms">
        <createTable tableName="chatbot_conversations">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="user_id" type="UUID"/>
            <column name="session_id" type="UUID"><constraints nullable="false"/></column>
            <column name="conversation_history" type="TEXT"/>
            <column name="intent" type="VARCHAR(100)"/>
            <column name="entities" type="TEXT"/>
            <column name="status" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="satisfaction_rating" type="INTEGER"/>
            <column name="was_escalated" type="BOOLEAN"/>
            <column name="escalated_to" type="UUID"/>
            <column name="resolved" type="BOOLEAN"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="073-create-smart-recommendations-table" author="hrms">
        <createTable tableName="smart_recommendations">
            <column name="id" type="UUID"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="UUID"><constraints nullable="false"/></column>
            <column name="target_type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="target_id" type="UUID"><constraints nullable="false"/></column>
            <column name="recommendation_type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="recommendation_data" type="TEXT"/>
            <column name="confidence_score" type="DOUBLE"/>
            <column name="priority" type="VARCHAR(20)"/>
            <column name="is_acted_upon" type="BOOLEAN"/>
            <column name="action_taken" type="TEXT"/>
            <column name="was_useful" type="BOOLEAN"/>
            <column name="ai_model_version" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="expires_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
