<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- PSA Projects -->
    <changeSet id="072-create-psa-projects-table" author="hrms">
        <createTable tableName="psa_projects">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="project_code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="project_name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="client_id" type="UUID"/>
            <column name="project_manager_id" type="UUID"/>
            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
            <column name="billing_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="billing_rate" type="DECIMAL(10,2)"/>
            <column name="budget" type="DECIMAL(15,2)"/>
            <column name="is_billable" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
        <createIndex tableName="psa_projects" indexName="idx_psa_proj_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="psa_projects" indexName="idx_psa_proj_code">
            <column name="project_code"/>
        </createIndex>
    </changeSet>

    <!-- PSA Timesheets -->
    <changeSet id="072-create-psa-timesheets-table" author="hrms">
        <createTable tableName="psa_timesheets">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="week_start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="week_end_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="total_hours" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="billable_hours" type="DOUBLE"/>
            <column name="non_billable_hours" type="DOUBLE"/>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="submitted_at" type="TIMESTAMP"/>
            <column name="approved_at" type="TIMESTAMP"/>
            <column name="approved_by" type="UUID"/>
            <column name="rejection_reason" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <createIndex tableName="psa_timesheets" indexName="idx_psa_ts_tenant_emp">
            <column name="tenant_id"/>
            <column name="employee_id"/>
        </createIndex>
        <createIndex tableName="psa_timesheets" indexName="idx_psa_ts_week">
            <column name="week_start_date"/>
        </createIndex>
    </changeSet>

    <!-- PSA Time Entries -->
    <changeSet id="072-create-psa-time-entries-table" author="hrms">
        <createTable tableName="psa_time_entries">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="timesheet_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="task_id" type="UUID"/>
            <column name="entry_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="hours" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="is_billable" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="work_description" type="TEXT"/>
            <column name="activity_type" type="VARCHAR(50)"/>
            <column name="is_overtime" type="BOOLEAN"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <createIndex tableName="psa_time_entries" indexName="idx_psa_te_timesheet">
            <column name="timesheet_id"/>
        </createIndex>
        <createIndex tableName="psa_time_entries" indexName="idx_psa_te_project">
            <column name="project_id"/>
        </createIndex>
        <createIndex tableName="psa_time_entries" indexName="idx_psa_te_employee">
            <column name="employee_id"/>
        </createIndex>
    </changeSet>

    <!-- PSA Project Allocations -->
    <changeSet id="072-create-psa-project-allocations-table" author="hrms">
        <createTable tableName="psa_project_allocations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="role_name" type="VARCHAR(100)"/>
            <column name="allocation_percentage" type="INTEGER"/>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE"/>
            <column name="billing_rate" type="DECIMAL(10,2)"/>
            <column name="is_active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
        <createIndex tableName="psa_project_allocations" indexName="idx_psa_alloc_project">
            <column name="project_id"/>
        </createIndex>
        <createIndex tableName="psa_project_allocations" indexName="idx_psa_alloc_employee">
            <column name="employee_id"/>
        </createIndex>
    </changeSet>

    <!-- PSA Invoices -->
    <changeSet id="072-create-psa-invoices-table" author="hrms">
        <createTable tableName="psa_invoices">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="invoice_number" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="project_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="client_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="invoice_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="due_date" type="DATE"/>
            <column name="billing_period_start" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="billing_period_end" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="total_hours" type="DOUBLE"/>
            <column name="billable_amount" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="tax_amount" type="DECIMAL(15,2)"/>
            <column name="total_amount" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="paid_at" type="TIMESTAMP"/>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
        <createIndex tableName="psa_invoices" indexName="idx_psa_inv_tenant_project">
            <column name="tenant_id"/>
            <column name="project_id"/>
        </createIndex>
        <createIndex tableName="psa_invoices" indexName="idx_psa_inv_number">
            <column name="invoice_number"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
