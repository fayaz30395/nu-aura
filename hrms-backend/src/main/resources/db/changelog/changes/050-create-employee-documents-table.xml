<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="050-create-employee-documents-table" author="hrms">
        <createTable tableName="employee_documents">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="employee_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="document_name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="file_path" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="file_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="file_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="upload_date" type="DATE"/>
            <column name="expiry_date" type="DATE"/>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="document_number" type="VARCHAR(500)"/>
            <column name="uploaded_by" type="UUID"/>
            <column name="verified_by" type="UUID"/>
            <column name="verified_date" type="DATE"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="employee_documents" indexName="idx_doc_tenant">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="employee_documents" indexName="idx_doc_employee">
            <column name="employee_id"/>
        </createIndex>

        <createIndex tableName="employee_documents" indexName="idx_doc_category">
            <column name="category"/>
        </createIndex>

        <createIndex tableName="employee_documents" indexName="idx_doc_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="employee_documents" indexName="idx_doc_expiry">
            <column name="expiry_date"/>
        </createIndex>

        <addForeignKeyConstraint
            baseTableName="employee_documents"
            baseColumnNames="employee_id"
            constraintName="fk_document_employee"
            referencedTableName="employees"
            referencedColumnNames="id"
            onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>
