<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="114-01" author="antigravity">
        <comment>Add office_location_id and team_id to employees table</comment>
        <addColumn tableName="employees">
            <column name="office_location_id" type="UUID"/>
            <column name="team_id" type="UUID"/>
        </addColumn>
    </changeSet>

    <changeSet id="114-02" author="antigravity">
        <comment>Add foreign keys for office_location_id and team_id in employees table</comment>
        <addForeignKeyConstraint baseTableName="employees"
                                 baseColumnNames="office_location_id"
                                 constraintName="fk_employee_office_location"
                                 referencedTableName="office_locations"
                                 referencedColumnNames="id"/>
        <!-- Note: teams table doesn't exist yet, but it's in the roadmap. 
             If it existed, we'd add the FK here. For now, it stays a UUID column. -->
    </changeSet>
</databaseChangeLog>
