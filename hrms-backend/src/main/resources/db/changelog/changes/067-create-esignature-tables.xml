<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="067-01-create-signature-requests-table" author="system">
        <createTable tableName="signature_requests">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="document_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="document_url" type="VARCHAR(1000)"/>
            <column name="document_name" type="VARCHAR(500)"/>
            <column name="document_size" type="BIGINT"/>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="created_by" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="required_signatures" type="INT"/>
            <column name="received_signatures" type="INT"/>
            <column name="signature_order" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="completed_at" type="TIMESTAMP"/>
            <column name="cancelled_at" type="TIMESTAMP"/>
            <column name="cancelled_by" type="UUID"/>
            <column name="cancellation_reason" type="TEXT"/>
            <column name="reminder_frequency_days" type="INT"/>
            <column name="last_reminder_sent_at" type="TIMESTAMP"/>
            <column name="is_template" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="template_name" type="VARCHAR(255)"/>
            <column name="metadata" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_sig_req_tenant" tableName="signature_requests">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_sig_req_creator" tableName="signature_requests">
            <column name="tenant_id"/>
            <column name="created_by"/>
        </createIndex>
        <createIndex indexName="idx_sig_req_status" tableName="signature_requests">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_sig_req_doc_type" tableName="signature_requests">
            <column name="tenant_id"/>
            <column name="document_type"/>
        </createIndex>
        <createIndex indexName="idx_sig_req_expires" tableName="signature_requests">
            <column name="tenant_id"/>
            <column name="expires_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="067-02-create-signature-approvals-table" author="system">
        <createTable tableName="signature_approvals">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="signature_request_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="signer_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="signer_email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="signer_role" type="VARCHAR(100)"/>
            <column name="signing_order" type="INT"/>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="is_required" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="signed_at" type="TIMESTAMP"/>
            <column name="signature_ip" type="VARCHAR(45)"/>
            <column name="signature_device" type="VARCHAR(255)"/>
            <column name="signature_method" type="VARCHAR(50)"/>
            <column name="signature_data" type="TEXT"/>
            <column name="declined_at" type="TIMESTAMP"/>
            <column name="decline_reason" type="TEXT"/>
            <column name="sent_at" type="TIMESTAMP"/>
            <column name="viewed_at" type="TIMESTAMP"/>
            <column name="reminder_count" type="INT" defaultValueNumeric="0"/>
            <column name="last_reminded_at" type="TIMESTAMP"/>
            <column name="comments" type="TEXT"/>
            <column name="authentication_token" type="VARCHAR(500)"/>
            <column name="token_expires_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_sig_appr_tenant" tableName="signature_approvals">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_sig_appr_request" tableName="signature_approvals">
            <column name="tenant_id"/>
            <column name="signature_request_id"/>
        </createIndex>
        <createIndex indexName="idx_sig_appr_signer" tableName="signature_approvals">
            <column name="tenant_id"/>
            <column name="signer_id"/>
        </createIndex>
        <createIndex indexName="idx_sig_appr_status" tableName="signature_approvals">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_sig_appr_order" tableName="signature_approvals">
            <column name="signature_request_id"/>
            <column name="signing_order"/>
        </createIndex>
    </changeSet>

    <changeSet id="067-03-add-foreign-keys" author="system">
        <addForeignKeyConstraint
                baseTableName="signature_approvals"
                baseColumnNames="signature_request_id"
                constraintName="fk_sig_appr_request"
                referencedTableName="signature_requests"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
