<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="062-create-benefit-plans-table" author="hrms">
        <createTable tableName="benefit_plans">
            <column name="id" type="uuid"><constraints primaryKey="true"/></column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="plan_code" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="plan_name" type="varchar(200)"><constraints nullable="false"/></column>
            <column name="description" type="text"/>
            <column name="benefit_type" type="varchar(50)"/>
            <column name="provider_id" type="uuid"/>
            <column name="coverage_amount" type="decimal(12,2)"/>
            <column name="employee_contribution" type="decimal(10,2)"/>
            <column name="employer_contribution" type="decimal(10,2)"/>
            <column name="effective_date" type="date"/>
            <column name="expiry_date" type="date"/>
            <column name="is_active" type="boolean" defaultValueBoolean="true"/>
            <column name="eligibility_criteria" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="version" type="bigint" defaultValue="0"/>
        </createTable>
        <addUniqueConstraint tableName="benefit_plans" columnNames="tenant_id, plan_code"/>
        <createIndex tableName="benefit_plans" indexName="idx_benefit_plan_tenant"><column name="tenant_id"/></createIndex>
    </changeSet>
</databaseChangeLog>
