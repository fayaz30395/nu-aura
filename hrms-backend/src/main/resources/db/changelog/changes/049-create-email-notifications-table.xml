<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="049-create-email-notifications-table" author="hrms">
        <createTable tableName="email_notifications">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="recipient_email" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="recipient_name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="subject" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="body" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="email_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="sent_at" type="TIMESTAMP"/>
            <column name="scheduled_at" type="TIMESTAMP"/>
            <column name="error_message" type="TEXT"/>
            <column name="retry_count" type="INT" defaultValueNumeric="0"/>
            <column name="metadata" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="email_notifications" indexName="idx_email_tenant">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="email_notifications" indexName="idx_email_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="email_notifications" indexName="idx_email_recipient">
            <column name="recipient_email"/>
        </createIndex>

        <createIndex tableName="email_notifications" indexName="idx_email_type">
            <column name="email_type"/>
        </createIndex>

        <createIndex tableName="email_notifications" indexName="idx_email_scheduled">
            <column name="scheduled_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
