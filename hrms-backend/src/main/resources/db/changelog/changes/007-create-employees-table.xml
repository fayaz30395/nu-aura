<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="007-create-employees-table" author="system">
        <createTable tableName="employees">
            <column name="id" type="uuid"><constraints primaryKey="true" nullable="false"/></column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="employee_code" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="user_id" type="uuid"><constraints nullable="false"/></column>
            <column name="first_name" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="middle_name" type="varchar(100)"/>
            <column name="last_name" type="varchar(100)"/>
            <column name="personal_email" type="varchar(200)"/>
            <column name="phone_number" type="varchar(20)"/>
            <column name="emergency_contact_number" type="varchar(20)"/>
            <column name="date_of_birth" type="date"/>
            <column name="gender" type="varchar(20)"/>
            <column name="address" type="text"/>
            <column name="city" type="varchar(100)"/>
            <column name="state" type="varchar(100)"/>
            <column name="postal_code" type="varchar(20)"/>
            <column name="country" type="varchar(100)"/>
            <column name="joining_date" type="date"><constraints nullable="false"/></column>
            <column name="confirmation_date" type="date"/>
            <column name="exit_date" type="date"/>
            <column name="department_id" type="uuid"/>
            <column name="designation" type="varchar(100)"/>
            <column name="manager_id" type="uuid"/>
            <column name="employment_type" type="varchar(20)"><constraints nullable="false"/></column>
            <column name="status" type="varchar(20)"><constraints nullable="false"/></column>
            <column name="bank_account_number" type="varchar(100)"/>
            <column name="bank_name" type="varchar(50)"/>
            <column name="bank_ifsc_code" type="varchar(50)"/>
            <column name="tax_id" type="varchar(50)"/>
            <column name="created_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="created_by" type="uuid"/>
            <column name="last_modified_by" type="uuid"/>
            <column name="version" type="bigint"/>
        </createTable>
        <addUniqueConstraint tableName="employees" columnNames="employee_code,tenant_id"/>
        <createIndex indexName="idx_employee_tenant" tableName="employees"><column name="tenant_id"/></createIndex>
        <createIndex indexName="idx_employee_status" tableName="employees"><column name="status"/></createIndex>
        <addForeignKeyConstraint baseTableName="employees" baseColumnNames="tenant_id" constraintName="fk_employee_tenant" referencedTableName="tenants" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="employees" baseColumnNames="user_id" constraintName="fk_employee_user" referencedTableName="users" referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>
